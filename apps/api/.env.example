# ─── Restora POS — Environment Variables ──────────────────────────────────────
# Copy this file to .env and fill in the values
# NEVER commit .env to git

# ── App ────────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev (matches docker-compose.yml)
DATABASE_URL="postgresql://restora:restora_dev_password@localhost:5432/restora_dev?schema=public"

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6380

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_generate_a_64_byte_hex_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=CHANGE_ME_generate_a_different_64_byte_hex_secret
JWT_REFRESH_EXPIRES_IN=30d

# ── File Storage (Cloudflare R2 / S3-compatible) ──────────────────────────────
# Leave empty for local dev (files saved locally)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=restora-assets
R2_PUBLIC_URL=

# ── Email (SendGrid) ──────────────────────────────────────────────────────────
SENDGRID_API_KEY=
EMAIL_FROM=noreply@restora.app

# ── Error Tracking (Sentry) ───────────────────────────────────────────────────
SENTRY_DSN=

# ── Feature Flags ─────────────────────────────────────────────────────────────
ENABLE_SWAGGER=true
