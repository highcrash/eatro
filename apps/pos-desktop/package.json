{
  "name": "@restora/pos-desktop",
  "version": "1.0.22",
  "private": true,
  "description": "Windows cashier terminal — Electron shell that wraps the web POS and adds native printing, cash drawer, and offline sync.",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "electron-rebuild -w better-sqlite3 && electron-vite dev",
    "build": "electron-rebuild -w better-sqlite3 && electron-vite build",
    "fetch-resources": "node scripts/fetch-sumatra.cjs",
    "dist": "pnpm fetch-resources && electron-rebuild -w better-sqlite3 && electron-vite build && electron-builder --win --config electron-builder.yml",
    "rebuild:native": "electron-rebuild -w better-sqlite3",
    "virtual-printer": "node scripts/virtual-thermal-printer.cjs",
    "type-check": "tsc --noEmit -p tsconfig.json",
    "clean": "rimraf dist release"
  },
  "dependencies": {
    "@restora/license-client": "github:highcrash/neawaslic#main&path:/packages/license-client",
    "@tanstack/react-query": "^5.62.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^11.3.0",
    "electron-log": "^5.2.0",
    "electron-updater": "^6.3.0",
    "lucide-react": "^0.468.0",
    "node-thermal-printer": "^4.5.0",
    "pngjs": "^7.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.54.0",
    "react-router-dom": "^6.28.0",
    "socket.io-client": "^4.8.0",
    "zod": "^3.23.8",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "@restora/config": "workspace:*",
    "@restora/types": "workspace:*",
    "@restora/utils": "workspace:*",
    "@types/better-sqlite3": "^7.6.11",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.5",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.49",
    "rimraf": "^6.0.0",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  }
}
