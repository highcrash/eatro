# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
build/
# Keep the desktop app's build resources (icons, installer assets) under vcs —
# those are source files, not generated artifacts.
!apps/pos-desktop/build/
!apps/pos-desktop/build/**
.next/
out/

# Environment
.env
.env.local
.env.*.local
!.env.example

# Logs
logs/
*.log
npm-debug.log*
pnpm-debug.log*

# Testing
coverage/
.playwright/
playwright-report/
test-results/

# Misc
.DS_Store
Thumbs.db
*.pem

# Turbo
.turbo/

# Prisma
prisma/migrations/dev.db
prisma/migrations/dev.db-journal

# IDEs
.vscode/
.idea/
*.swp
*.swo

# Docker
infra/postgres-data/
infra/redis-data/

# TypeScript build artifacts leaked into src directories
packages/*/src/**/*.js
packages/*/src/**/*.js.map
packages/*/src/**/*.d.ts
packages/*/src/**/*.d.ts.map
*.tsbuildinfo

# Uploaded files
apps/api/uploads/

# Database backups (sensitive — contains all data)
apps/api/backups/

# Stray nested path created when the api is started with a non-root cwd
apps/api/apps/

# Claude Code local settings
.claude/settings.local.json

# ─────────────────────────────────────────────────────────────────────────────
# codecanyon fork — main-only files
#
# These paths exist on `main` (internal development / deploy config) but must
# NOT travel with the `codecanyon` branch. Two gates keep them out:
#   1. This ignore list — git stops tracking them on codecanyon once removed.
#   2. scripts/lib/secret-scan.mjs — packager fails the build if any internal
#      token leaks into the release tree anyway.
#
# When you add a new internal-only file, list it here AND in
# codecanyon/docs/BRANCH_HYGIENE.md.
# ─────────────────────────────────────────────────────────────────────────────
.do/
scripts/screenshot.mjs
scripts/screenshot-pos.mjs
scripts/seed-attendance.mjs
scripts/seed-sales.mjs
mockups/
temporary screenshots/

