// ─── Restora POS — Prisma Schema ──────────────────────────────────────────────
// Phase 1: Core POS & Orders
// Database: PostgreSQL 15
// Monetary values: Decimal(14,2) stored as smallest unit (paisa)
// Quantities:      Decimal(14,4) for sub-gram/ml accuracy
// All tables use soft deletes (deletedAt) and audit fields

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────────────

enum UserRole {
  OWNER
  MANAGER
  CASHIER
  KITCHEN
  WAITER
  ADVISOR
}

enum OrderType {
  DINE_IN
  TAKEAWAY
  DELIVERY
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  SERVED
  PAID
  VOID
  REFUNDED
  PARTIALLY_REFUNDED
}

// ─────────────────────────────────────────────────────────────────────────────
// NBR (Bangladesh) MUSHAK VAT COMPLIANCE
// ─────────────────────────────────────────────────────────────────────────────

enum MushakNoteType {
  CREDIT // refund / return — negative totals, reverses a 6.3
  DEBIT  // supplementary charge — positive totals, adds to a 6.3
}

enum RefundReason {
  CUSTOMER_RETURN
  PRICING_ERROR
  DUPLICATE
  DAMAGED
  OTHER
}

// ─────────────────────────────────────────────────────────────────────────────
// PAYMENT METHODS — Two-level: Category → Options
// ─────────────────────────────────────────────────────────────────────────────

// Level 1: Payment Category (e.g., CASH, CARD, MFS, DIGITAL, FOOD_DELIVERY)
model PaymentMethodConfig {
  id        String  @id @default(cuid())
  branchId  String
  code      String  // CASH, CARD, MFS, DIGITAL, FOOD_DELIVERY
  name      String  // "Cash", "Card", "Mobile Banking", "Digital Payment", "Food Delivery"
  isActive  Boolean @default(true)
  sortOrder Int     @default(0)
  createdAt DateTime @default(now())

  // Relations
  branch  Branch          @relation(fields: [branchId], references: [id])
  options PaymentOption[]

  @@unique([branchId, code])
  @@index([branchId, isActive])
  @@map("payment_method_configs")
}

// Level 2: Payment Option (e.g., "City POS" under CARD, "bKash" under MFS)
model PaymentOption {
  id              String  @id @default(cuid())
  branchId        String
  categoryId      String  // links to PaymentMethodConfig
  code            String  // CITY_POS, DBBL_POS, BKASH, NAGAD, FOOD_PANDA
  name            String  // "City POS Machine", "bKash", "Food Panda"
  accountId       String? // linked Account for balance tracking
  isActive        Boolean @default(true)
  isDefault       Boolean @default(false) // default option in its category
  sortOrder       Int     @default(0)
  createdAt       DateTime @default(now())

  // Relations
  branch   Branch              @relation(fields: [branchId], references: [id])
  category PaymentMethodConfig @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  account  Account?            @relation(fields: [accountId], references: [id])

  @@unique([branchId, code])
  @@index([branchId, categoryId, isActive])
  @@map("payment_options")
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  CLEANING
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  ARRIVED
  COMPLETED
  NO_SHOW
  CANCELLED
}

enum KitchenTicketStatus {
  NEW
  PENDING_APPROVAL
  ACKNOWLEDGED
  PREPARING
  DONE
  RECALLED
}

enum MenuItemType {
  FOOD
  BEVERAGE
  MODIFIER
}

enum DiscountType {
  FLAT
  PERCENTAGE
}

enum DiscountScope {
  ALL_ITEMS
  SPECIFIC_ITEMS
  ALL_EXCEPT
}

// ─────────────────────────────────────────────────────────────────────────────
// BRANCH
// ─────────────────────────────────────────────────────────────────────────────

model Branch {
  id        String   @id @default(cuid())
  name      String
  address   String
  phone     String
  email     String?
  currency  String   @default("BDT")
  timezone  String   @default("Asia/Dhaka")
  taxRate   Decimal  @default(0) @db.Decimal(5, 2)   // percentage e.g. 15.00
  vatEnabled Boolean @default(true)                   // master toggle — when false, taxRate is ignored on new orders
  serviceChargeEnabled Boolean @default(false)        // adds a service charge line above VAT
  serviceChargeRate    Decimal @default(0) @db.Decimal(5, 2) // percentage e.g. 10.00
  stockPricingMethod String @default("LAST_PURCHASE") // LAST_PURCHASE or WEIGHTED_AVERAGE
  // ── Branding ──
  logoUrl              String? // main brand logo (used in admin, web, and as POS fallback)
  posLogoUrl           String? // optional override for POS sidebar
  websiteTagline       String? // hero tagline for the public website
  billHeaderText       String? // optional header text rendered above items on bill/receipt
  billFooterText       String? // free text shown at bottom of bills/receipts (multi-line)
  bin                  String? // Bangladesh Business Identification Number, shown under phone
  mushakVersion        String? // e.g. "Mushak-6.3" — printed below BIN on paper bills
  // ── NBR / Mushak compliance ──
  nbrEnabled           Boolean   @default(false)
  branchCode           String? // e.g. "DHK"; required when nbrEnabled=true
  sellerLegalName      String? // legal business name; falls back to `name`
  sellerTradingName    String? // trading / brand name; falls back to `name`
  wifiPass             String? // guest Wi-Fi password, optionally printed on the bill
  wifiSsid             String? // guest Wi-Fi network name (SSID) — shown on QR gate page
  qrGateEnabled        Boolean   @default(false) // when true, QR ordering requires the client IP to match qrAllowedIps
  qrAllowedIps         String? // comma-separated IPs and CIDR blocks (e.g. "192.168.1.0/24,203.0.113.42")
  qrGateMessage        String? // optional instructions shown under Wi-Fi details on the gate page
  billLogoWidthPct     Int       @default(80) // how wide the logo prints on the receipt (% of 80mm paper)
  facebookUrl          String?
  instagramUrl         String?
  isActive             Boolean   @default(true)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  deletedAt            DateTime?

  // Relations
  staff               Staff[]
  tables              DiningTable[]
  categories          MenuCategory[]
  menuItems           MenuItem[]
  orders              Order[]
  suppliers           Supplier[]
  ingredients         Ingredient[]
  stockMovements      StockMovement[]
  purchaseOrders      PurchaseOrder[]
  attendance          Attendance[]
  payrolls            Payroll[]
  wasteLogs           WasteLog[]
  expenses            Expense[]
  accounts            Account[]
  accountTransactions AccountTransaction[]
  preReadyItems       PreReadyItem[]
  productionOrders    ProductionOrder[]
  preReadyBatches     PreReadyBatch[]
  supplierPayments    SupplierPayment[]
  leaveApplications   LeaveApplication[]
  workPeriods         WorkPeriod[]
  cookingStations     CookingStation[]
  unitConversions     UnitConversion[]
  customUnits         CustomUnit[]
  paymentMethods      PaymentMethodConfig[]
  paymentOptions      PaymentOption[]
  purchaseReturns     PurchaseReturn[]
  discounts           Discount[]
  coupons             Coupon[]
  customers           Customer[]
  reviews             Review[]
  reservations        Reservation[]
  settings            BranchSetting?
  websiteContent      WebsiteContent?
  devices             Device[]
  mushakSequences     MushakSequence[]
  mushakInvoices      MushakInvoice[]
  mushakNotes         MushakNote[]

  @@index([isActive])
  @@map("branches")
}

model BranchSetting {
  id        String  @id @default(cuid())
  branchId  String  @unique
  // SMS Gateway
  smsEnabled       Boolean @default(false)
  smsApiKey        String?
  smsApiUrl        String  @default("https://api.sms.net.bd/sendsms")
  // Notification toggles
  notifyVoidOtp                   Boolean @default(true) // Send OTP to manager for void approval
  smsPaymentNotifyEnabled         Boolean @default(false) // Auto-send thank-you SMS to customer on order payment
  smsPaymentTemplate              String? // Payment SMS body; supports {{name}} + {{amount}} + {{method}} placeholders
  // Theming
  posTheme         String  @default("sunrise")  // built-in slug or custom slug
  websiteTheme     String  @default("sunrise")
  customThemes     String? // JSON array of custom theme objects (slug, name, scope, tokens)
  // Cashier permissions (Phase 6)
  cashierPermissions String? // JSON: per-action enabled+approval mode
  // Kitchen
  useKds             Boolean @default(true)  // When false, kitchen tickets auto-print from POS (no KDS screen)
  // ── Reservation Settings ──
  openingTime                     String  @default("09:00")
  closingTime                     String  @default("23:00")
  reservationSlotMinutes          Int     @default(90)
  reservationBlockMinutes         Int     @default(60)
  reservationMaxBookingsPerSlot   Int     @default(12)
  reservationMaxPersonsPerSlot    Int     @default(40)
  reservationAutoReserveMinutes   Int     @default(30)
  reservationLateThresholdMinutes Int     @default(30)
  reservationSmsEnabled           Boolean @default(true)
  reservationReminderMinutes      Int     @default(60)
  reservationSmsConfirmTemplate   String?
  reservationSmsRejectTemplate    String?
  reservationSmsReminderTemplate  String?
  reservationTermsOfService       String?

  branch Branch @relation(fields: [branchId], references: [id])

  @@map("branch_settings")
}

// ─── Website CMS (Phase 5) ───────────────────────────────────────────────────
model WebsiteContent {
  id            String   @id @default(cuid())
  branchId      String   @unique
  // Hero
  heroTitle     String   @default("Welcome")
  heroSubtitle  String?
  heroImageUrl  String?
  heroVideoUrl  String?                          // MP4 URL for hero background video
  heroCtaText   String   @default("View Menu")
  // About
  aboutTitle    String   @default("About Us")
  aboutBody     String   @default("")
  aboutImageUrl String?
  aboutPoint1   String?                          // numbered about card 1
  aboutPoint2   String?
  aboutPoint3   String?
  aboutPoint4   String?
  openingHours  String?                          // "Daily 11:00 - 23:00"
  // Contact
  contactNote   String?
  mapEmbedUrl   String?
  // Featured menu (JSON array of MenuCategory ids)
  featuredCategoryIds String?
  // Section visibility toggles
  showReservation     Boolean @default(true)
  showReviews         Boolean @default(true)
  showGallery         Boolean @default(true)
  showKeyIngredients  Boolean @default(true)
  showPieces          Boolean @default(true)
  showPrepTime        Boolean @default(true)
  showSpiceLevel      Boolean @default(true)
  showDeals           Boolean @default(true)
  showChefsSpecial    Boolean @default(true)
  // Gallery
  galleryImages       String?                    // JSON array of image URLs
  // Section backgrounds (admin uploads image/video)
  menuSectionBg       String?
  aboutSectionBg      String?
  reviewsSectionBg    String?
  reservationSectionBg String?
  contactSectionBg    String?
  bannerBg            String?                    // full-width banner image
  bannerText          String?                    // banner large text
  // Theme & Colors
  websiteMode         String  @default("dark")   // "dark" | "light"
  maintenanceMode     Boolean @default(false)    // when true, website shows maintenance page
  maintenanceBg       String?                    // background image for maintenance page
  maintenanceText     String?                    // custom maintenance text
  notFoundBg          String?                    // background image for 404 page
  notFoundText        String?                    // custom 404 text
  // SEO — Global
  seoSiteName         String?                    // e.g. "EATRO Restaurant"
  seoHomeTitle        String?                    // Home page title tag
  seoHomeDescription  String?                    // Home page meta description
  seoHomeKeywords     String?                    // comma-separated keywords
  seoMenuTitle        String?                    // Menu page title
  seoMenuDescription  String?
  seoAboutTitle       String?
  seoAboutDescription String?
  seoContactTitle     String?
  seoContactDescription String?
  seoReservationTitle String?
  seoReservationDescription String?
  seoOgImage          String?                    // default Open Graph image
  seoFavicon          String?                    // favicon URL
  // Marketing tags injected into the public website's <head> at runtime.
  // Admin pastes the raw ID (not the whole snippet) and the web app
  // injects the standard loader script.
  fbPixelId           String?                    // Facebook Pixel ID, e.g. "123456789012345"
  googleAnalyticsId   String?                    // GA4 Measurement ID ("G-XXXXXXXXXX") or GTM container ("GTM-XXXXXX")
  accentColor         String  @default("#D62B2B")
  buttonColor         String  @default("#D62B2B")
  textColor           String?                    // override (null = mode default)
  bgColor             String?                    // override (null = mode default)
  // Menu visibility
  recommendedTag      String  @default("Chef Special")
  hiddenCategoryIds   String?                    // JSON array of category IDs
  hiddenItemIds       String?                    // JSON array of item IDs
  //
  updatedAt     DateTime @updatedAt

  branch Branch @relation(fields: [branchId], references: [id])

  @@map("website_content")
}

// ─────────────────────────────────────────────────────────────────────────────
// STAFF
// ─────────────────────────────────────────────────────────────────────────────

model Staff {
  id           String    @id @default(cuid())
  branchId     String
  name         String
  email        String    @unique
  passwordHash String
  phone        String?
  role         UserRole  @default(CASHIER)
  isActive     Boolean   @default(true)
  // Whether this user can sign into a POS terminal (desktop lock-screen
  // tile + web POS login). Admin can flip off for roles that shouldn't
  // be operating a register (e.g. an ADVISOR who only needs admin).
  // OWNER/MANAGER are treated as always-allowed at the gate regardless.
  canAccessPos Boolean   @default(true)
  hireDate      DateTime  @default(now())
  monthlySalary Decimal?  @db.Decimal(14, 2)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  // Relations
  branch                Branch          @relation(fields: [branchId], references: [id])
  ordersAsCashier       Order[]         @relation("OrderCashier")
  voidedOrders          Order[]         @relation("OrderVoidedBy")
  purchaseOrdersCreated PurchaseOrder[] @relation("POCreatedBy")
  attendance            Attendance[]
  payrolls              Payroll[]
  payrollsApproved      Payroll[]       @relation("PayrollApprover")
  payrollPayments       PayrollPayment[] @relation("PayrollPaidBy")
  wasteLogsRecorded     WasteLog[]      @relation("WasteRecorder")
  expensesRecorded      Expense[]       @relation("ExpenseRecordedBy")
  expensesApproved      Expense[]       @relation("ExpenseApprover")
  productionOrdersRequested ProductionOrder[] @relation("ProductionRequester")
  productionOrdersApproved  ProductionOrder[] @relation("ProductionApprover")
  supplierPayments          SupplierPayment[] @relation("SupplierPaymentBy")
  leaveApplications         LeaveApplication[] @relation("LeaveApplicant")
  leaveReviews              LeaveApplication[] @relation("LeaveReviewer")
  workPeriodsStarted        WorkPeriod[]       @relation("WorkPeriodStarter")
  workPeriodsEnded          WorkPeriod[]       @relation("WorkPeriodEnder")
  ordersAsWaiter            Order[]            @relation("OrderWaiter")
  returnsRequested          PurchaseReturn[]   @relation("ReturnRequester")
  reservationsConfirmed     Reservation[]      @relation("ReservationConfirmer")
  mushakNotesIssued         MushakNote[]       @relation("MushakNoteIssuer")

  @@index([branchId, isActive])
  @@index([email])
  @@map("staff")
}

// ─────────────────────────────────────────────────────────────────────────────
// DINING TABLES
// ─────────────────────────────────────────────────────────────────────────────

model DiningTable {
  id          String      @id @default(cuid())
  branchId    String
  tableNumber String
  capacity    Int         @default(4)
  status      TableStatus @default(AVAILABLE)
  floorPlanX  Float?
  floorPlanY  Float?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  deletedAt   DateTime?

  // Relations
  branch       Branch        @relation(fields: [branchId], references: [id])
  orders       Order[]
  reservations Reservation[]

  @@unique([branchId, tableNumber])
  @@index([branchId, status])
  @@map("dining_tables")
}

// ─────────────────────────────────────────────────────────────────────────────
// MENU
// ─────────────────────────────────────────────────────────────────────────────

model MenuCategory {
  id        String    @id @default(cuid())
  branchId  String
  parentId  String?
  name      String
  slug      String?   // SEO-friendly URL slug (auto-generated from name)
  icon      String?   // emoji or icon name (e.g. "🍗", "🍕", "☕")
  sortOrder Int       @default(0)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  websiteVisible Boolean @default(true)  // hide entire category from public website

  // Relations
  branch    Branch         @relation(fields: [branchId], references: [id])
  parent    MenuCategory?  @relation("CategoryParent", fields: [parentId], references: [id])
  children  MenuCategory[] @relation("CategoryParent")
  menuItems MenuItem[]

  @@index([branchId, sortOrder])
  @@map("menu_categories")
}

model MenuItem {
  id          String       @id @default(cuid())
  branchId    String
  categoryId  String
  name        String
  slug        String?                              // SEO-friendly URL slug
  seoTitle    String?                              // custom SEO title for this item
  seoDescription String?                           // custom meta description
  description String?
  type        MenuItemType @default(FOOD)
  price       Decimal      @db.Decimal(14, 2)   // stored in paisa
  costPrice   Decimal?     @db.Decimal(14, 2)
  imageUrl    String?
  tags        String?      // comma-separated: "vegan,spicy,nut-free,chicken"
  isAvailable Boolean      @default(true)
  sortOrder   Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?

  isCombo           Boolean      @default(false)
  cookingStationId  String?
  // Website detail fields
  pieces            String?                        // e.g. "4-6" — null = don't show
  prepTime          String?                        // e.g. "15 min"
  spiceLevel        String?                        // e.g. "Mild", "Medium", "Hot"
  websiteVisible    Boolean      @default(true)    // hide from website without affecting POS

  // Relations
  branch           Branch          @relation(fields: [branchId], references: [id])
  category         MenuCategory    @relation(fields: [categoryId], references: [id])
  cookingStation   CookingStation? @relation(fields: [cookingStationId], references: [id])
  orderItems       OrderItem[]
  recipe           Recipe?
  comboItems       ComboItem[]     @relation("ComboMenu")
  includedInCombos ComboItem[]     @relation("ComboIncluded")
  linkedItems      LinkedItem[]    @relation("LinkedParent")
  linkedFrom       LinkedItem[]    @relation("LinkedChild")
  menuDiscounts    MenuItemDiscount[]

  @@index([branchId, categoryId, isAvailable])
  @@index([branchId, sortOrder])
  @@map("menu_items")
}

// ─────────────────────────────────────────────────────────────────────────────
// COMBO & LINKED ITEMS
// ─────────────────────────────────────────────────────────────────────────────

model ComboItem {
  id             String @id @default(cuid())
  comboMenuId    String
  includedItemId String
  quantity       Int    @default(1)

  // Relations
  comboMenu    MenuItem @relation("ComboMenu", fields: [comboMenuId], references: [id], onDelete: Cascade)
  includedItem MenuItem @relation("ComboIncluded", fields: [includedItemId], references: [id])

  @@unique([comboMenuId, includedItemId])
  @@map("combo_items")
}

enum LinkedItemType {
  FREE
  COMPLEMENTARY
}

model LinkedItem {
  id              String         @id @default(cuid())
  parentMenuId    String
  linkedMenuId    String
  type            LinkedItemType @default(FREE)
  triggerQuantity Int            @default(1)
  freeQuantity    Int            @default(1)

  // Relations
  parentMenu MenuItem @relation("LinkedParent", fields: [parentMenuId], references: [id], onDelete: Cascade)
  linkedMenu MenuItem @relation("LinkedChild", fields: [linkedMenuId], references: [id])

  @@unique([parentMenuId, linkedMenuId])
  @@map("linked_items")
}

// ─────────────────────────────────────────────────────────────────────────────
// CUSTOMERS
// ─────────────────────────────────────────────────────────────────────────────

model Customer {
  id          String    @id @default(cuid())
  branchId    String
  phone       String
  name        String    @default("Walk-in")
  email       String?
  totalOrders Int       @default(0)
  totalSpent  Decimal   @default(0) @db.Decimal(14, 2)
  lastVisit   DateTime?
  agreedTerms Boolean   @default(true)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  branch       Branch        @relation(fields: [branchId], references: [id])
  orders       Order[]
  reviews      Review[]
  reservations Reservation[]

  @@unique([branchId, phone])
  @@index([branchId, phone])
  @@map("customers")
}

model Review {
  id             String   @id @default(cuid())
  branchId       String
  orderId        String   @unique
  customerId     String?
  foodScore      Int      // 1-5
  serviceScore   Int      // 1-5
  atmosphereScore Int     // 1-5
  priceScore     Int      // 1-5
  notes          String?
  createdAt      DateTime @default(now())

  branch   Branch    @relation(fields: [branchId], references: [id])
  order    Order     @relation(fields: [orderId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])

  @@index([branchId])
  @@map("reviews")
}

// ─────────────────────────────────────────────────────────────────────────────
// RESERVATIONS
// ─────────────────────────────────────────────────────────────────────────────

model Reservation {
  id              String            @id @default(cuid())
  branchId        String
  customerId      String?
  customerName    String
  customerPhone   String
  date            DateTime          @db.Date
  timeSlot        String                            // "HH:mm" start time
  partySize       Int
  status          ReservationStatus @default(PENDING)
  tableId         String?
  tableIds        String?                           // JSON array of table IDs for multi-table bookings
  notes           String?
  confirmedById   String?
  confirmedAt     DateTime?
  arrivedAt       DateTime?
  completedAt     DateTime?
  cancelledAt     DateTime?
  cancelReason    String?
  agreedTerms     Boolean           @default(true)
  reminderSentAt  DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  branch      Branch       @relation(fields: [branchId], references: [id])
  customer    Customer?    @relation(fields: [customerId], references: [id])
  table       DiningTable? @relation(fields: [tableId], references: [id])
  confirmedBy Staff?       @relation("ReservationConfirmer", fields: [confirmedById], references: [id])

  @@index([branchId, date, status])
  @@index([branchId, status])
  @@index([customerPhone])
  @@map("reservations")
}

// ─────────────────────────────────────────────────────────────────────────────
// ORDERS
// ─────────────────────────────────────────────────────────────────────────────

model Order {
  id                  String      @id @default(cuid())
  orderNumber         String      @unique
  branchId            String
  cashierId           String
  tableId             String?
  tableNumber         String? // denormalized — survives table deletion
  type                OrderType   @default(DINE_IN)
  status              OrderStatus @default(PENDING)
  notes               String?
  subtotal            Decimal     @db.Decimal(14, 2)
  taxAmount           Decimal     @default(0) @db.Decimal(14, 2)
  serviceChargeAmount Decimal     @default(0) @db.Decimal(14, 2) // added before VAT when branch.serviceChargeEnabled
  discountAmount      Decimal     @default(0) @db.Decimal(14, 2)
  discountId          String? // applied Discount ID
  discountName        String? // denormalized discount/coupon display name
  couponId            String? // applied Coupon ID
  couponCode          String? // denormalized coupon code
  totalAmount         Decimal     @db.Decimal(14, 2)
  // Auto rounding to the nearest taka (100 paisa). Signed delta in paisa;
  // positive when the bill was rounded UP, negative when rounded DOWN.
  // totalAmount already includes this adjustment — receipts print an
  // "Auto Roundup (+0.30)" line below VAT to make the delta visible.
  roundAdjustment     Decimal     @default(0) @db.Decimal(14, 2)
  paymentMethod       String?
  paidAt              DateTime?
  customerId          String?
  customerName        String? // denormalized — "Walk-in" or customer name
  customerPhone       String? // denormalized
  waiterId            String?
  guestCount          Int         @default(0) // number of guests at the table (printed on bill/receipt)
  billRequested       Boolean     @default(false)
  voidReason          String?
  voidedById          String?
  voidedAt            DateTime?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  deletedAt           DateTime?

  // Relations
  branch   Branch         @relation(fields: [branchId], references: [id])
  cashier  Staff          @relation("OrderCashier", fields: [cashierId], references: [id])
  table    DiningTable?   @relation(fields: [tableId], references: [id])
  customer Customer?      @relation(fields: [customerId], references: [id])
  review   Review?
  waiter   Staff?         @relation("OrderWaiter", fields: [waiterId], references: [id])
  voidedBy Staff?         @relation("OrderVoidedBy", fields: [voidedById], references: [id])
  items    OrderItem[]
  payments OrderPayment[]
  mushakInvoice MushakInvoice?
  mushakNotes   MushakNote[]

  @@index([branchId, status])
  @@index([branchId, createdAt])
  @@index([orderNumber])
  @@map("orders")
}

model OrderItem {
  id            String              @id @default(cuid())
  orderId       String
  menuItemId    String
  menuItemName  String              // denormalized — survives menu item deletion
  quantity      Int
  unitPrice     Decimal             @db.Decimal(14, 2)
  totalPrice    Decimal             @db.Decimal(14, 2)
  notes         String?
  kitchenStatus KitchenTicketStatus @default(NEW)
  voidedAt      DateTime?
  voidReason    String?
  voidedById    String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  // Relations
  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem MenuItem @relation(fields: [menuItemId], references: [id])

  @@index([orderId])
  @@index([menuItemId])
  @@map("order_items")
}

model OrderPayment {
  id        String        @id @default(cuid())
  orderId   String
  method    String
  amount    Decimal       @db.Decimal(14, 2)
  reference String?       // transaction ref for CARD/MFS
  createdAt DateTime      @default(now())

  // Relations
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_payments")
}

// ─────────────────────────────────────────────────────────────────────────────
// DISCOUNTS & COUPONS
// ─────────────────────────────────────────────────────────────────────────────

model Discount {
  id          String        @id @default(cuid())
  branchId    String
  name        String
  type        DiscountType  // FLAT or PERCENTAGE
  value       Decimal       @db.Decimal(14, 2) // paisa for FLAT, percentage for PERCENTAGE
  scope       DiscountScope @default(ALL_ITEMS)
  targetItems String?       // JSON array of menuItemIds (for SPECIFIC_ITEMS / ALL_EXCEPT)
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  branch Branch @relation(fields: [branchId], references: [id])

  @@index([branchId, isActive])
  @@map("discounts")
}

model Coupon {
  id          String        @id @default(cuid())
  branchId    String
  code        String
  name        String
  type        DiscountType
  value       Decimal       @db.Decimal(14, 2)
  scope       DiscountScope @default(ALL_ITEMS)
  targetItems String?
  maxUses     Int           @default(0) // 0 = unlimited
  usedCount   Int           @default(0)
  expiresAt   DateTime?
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  branch Branch @relation(fields: [branchId], references: [id])

  @@unique([branchId, code])
  @@index([branchId, isActive])
  @@map("coupons")
}

model MenuItemDiscount {
  id             String       @id @default(cuid())
  menuItemId     String
  type           DiscountType
  value          Decimal      @db.Decimal(14, 2)
  startDate      DateTime
  endDate        DateTime
  applicableDays String?      // JSON array like ["FRIDAY","SUNDAY"], null = all days
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  menuItem MenuItem @relation(fields: [menuItemId], references: [id])

  @@index([menuItemId, isActive])
  @@map("menu_item_discounts")
}

// ─────────────────────────────────────────────────────────────────────────────
// EXPENSE MANAGEMENT
// ─────────────────────────────────────────────────────────────────────────────

enum ExpenseCategory {
  RENT
  UTILITIES
  SALARY
  SUPPLIES
  MAINTENANCE
  TRANSPORT
  MARKETING
  FOOD_COST
  STAFF_FOOD
  MISCELLANEOUS
}

model Expense {
  id          String          @id @default(cuid())
  branchId    String
  category    ExpenseCategory @default(MISCELLANEOUS)
  description String
  amount      Decimal         @db.Decimal(14, 2) // in paisa
  paymentMethod String        @default("CASH")
  reference   String?
  date        DateTime        @db.Date
  recordedById String
  approvedById String?
  approvedAt   DateTime?
  notes       String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  deletedAt   DateTime?

  // Relations
  branch     Branch @relation(fields: [branchId], references: [id])
  recordedBy Staff  @relation("ExpenseRecordedBy", fields: [recordedById], references: [id])
  approvedBy Staff? @relation("ExpenseApprover", fields: [approvedById], references: [id])

  @@index([branchId, date])
  @@index([branchId, category])
  @@map("expenses")
}

// ─────────────────────────────────────────────────────────────────────────────
// ACCOUNT MANAGEMENT
// ─────────────────────────────────────────────────────────────────────────────

enum AccountType {
  CASH
  BANK
  MFS
  POS_TERMINAL
}

model Account {
  id          String      @id @default(cuid())
  branchId    String
  type        AccountType
  name        String      // e.g. "Main Cash Register", "bKash", "Dutch-Bangla Bank"
  balance             Decimal     @default(0) @db.Decimal(14, 2)
  isActive            Boolean     @default(true)
  showInPOS           Boolean     @default(false)  // show in POS opening/closing balance
  linkedPaymentMethod String?                      // CASH, MFS, CARD — links this account to a payment method
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Relations
  branch       Branch              @relation(fields: [branchId], references: [id])
  transactions   AccountTransaction[]
  paymentOptions PaymentOption[]

  @@unique([branchId, type, name])
  @@index([branchId, isActive])
  @@map("accounts")
}

enum TransactionType {
  SALE
  EXPENSE
  PURCHASE_PAYMENT
  TRANSFER
  ADJUSTMENT
}

model AccountTransaction {
  id           String          @id @default(cuid())
  branchId     String
  accountId    String
  type         TransactionType
  amount       Decimal         @db.Decimal(14, 2)  // positive = IN, negative = OUT
  description  String
  referenceId  String?         // orderId, expenseId, purchaseOrderId
  createdAt    DateTime        @default(now())

  // Relations
  branch  Branch  @relation(fields: [branchId], references: [id])
  account Account @relation(fields: [accountId], references: [id])

  @@index([branchId, createdAt])
  @@index([accountId])
  @@map("account_transactions")
}

// ─────────────────────────────────────────────────────────────────────────────
// PRE-READY FOODS
// ─────────────────────────────────────────────────────────────────────────────

enum ProductionStatus {
  PENDING       // awaiting manager approval
  APPROVED      // approved, ready to produce
  IN_PROGRESS   // kitchen is making it
  COMPLETED     // done, stock updated
  WASTED        // produced but result was bad — ingredients deducted, no batch created
  CANCELLED
}

model PreReadyItem {
  id          String    @id @default(cuid())
  branchId    String
  name        String
  unit        StockUnit @default(PCS)
  currentStock Decimal  @default(0) @db.Decimal(14, 4)
  minimumStock Decimal  @default(0) @db.Decimal(14, 4)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  // Relations
  branch           Branch                @relation(fields: [branchId], references: [id])
  recipe           PreReadyRecipe?
  productionOrders ProductionOrder[]
  batches          PreReadyBatch[]

  @@index([branchId, isActive])
  @@map("pre_ready_items")
}

model PreReadyRecipe {
  id             String   @id @default(cuid())
  preReadyItemId String   @unique
  yieldQuantity  Decimal  @db.Decimal(14, 4)  // how much 1 recipe produces (e.g. 1000 for 1L sauce)
  yieldUnit      StockUnit @default(G)
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  preReadyItem PreReadyItem          @relation(fields: [preReadyItemId], references: [id])
  items        PreReadyRecipeItem[]

  @@map("pre_ready_recipes")
}

model PreReadyRecipeItem {
  id           String  @id @default(cuid())
  recipeId     String
  ingredientId String
  quantity     Decimal   @db.Decimal(14, 4) // per 1 full recipe yield
  unit         StockUnit @default(G)        // unit of the quantity (may differ from ingredient's unit)

  // Relations
  recipe     PreReadyRecipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredient Ingredient     @relation(fields: [ingredientId], references: [id])

  @@unique([recipeId, ingredientId])
  @@map("pre_ready_recipe_items")
}

model ProductionOrder {
  id              String           @id @default(cuid())
  branchId        String
  preReadyItemId  String
  quantity        Decimal          @db.Decimal(14, 4) // how much to produce
  status          ProductionStatus @default(PENDING)
  requestedById   String
  approvedById    String?
  approvedAt      DateTime?
  completedAt     DateTime?
  notes           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  // Relations
  branch       Branch       @relation(fields: [branchId], references: [id])
  preReadyItem PreReadyItem @relation(fields: [preReadyItemId], references: [id])
  requestedBy  Staff        @relation("ProductionRequester", fields: [requestedById], references: [id])
  approvedBy   Staff?       @relation("ProductionApprover", fields: [approvedById], references: [id])

  @@index([branchId, status])
  @@map("production_orders")
}

model PreReadyBatch {
  id              String    @id @default(cuid())
  branchId        String
  preReadyItemId  String
  quantity        Decimal   @db.Decimal(14, 4)
  remainingQty    Decimal   @db.Decimal(14, 4)
  makingDate      DateTime  @db.Date
  expiryDate      DateTime  @db.Date
  createdAt       DateTime  @default(now())

  // Relations
  branch       Branch       @relation(fields: [branchId], references: [id])
  preReadyItem PreReadyItem @relation(fields: [preReadyItemId], references: [id])

  @@index([branchId, expiryDate])
  @@index([preReadyItemId])
  @@map("pre_ready_batches")
}

// ─────────────────────────────────────────────────────────────────────────────
// PHASE 2 — INVENTORY & RECIPE ENGINE
// ─────────────────────────────────────────────────────────────────────────────

enum SupplierCategory {
  MEAT
  FISH
  VEGETABLES
  DAIRY
  SPICES
  CLEANING
  PACKAGING
  BEVERAGE
  GENERAL
}

enum IngredientCategory {
  RAW
  CLEANING
  PACKAGED
  SPICE
  DAIRY
  BEVERAGE
  OTHER
}

enum StockMovementType {
  PURCHASE      // stock received from supplier
  SALE          // auto-deducted on order creation
  VOID_RETURN   // returned when order item is voided
  ADJUSTMENT    // manual stock correction
  WASTE         // waste/spoilage write-off
}

enum StockUnit {
  KG
  G
  L
  ML
  PCS
  DOZEN
  BOX
  PACKET
  PACK
  BOTTLE
  BAG
  BUNDLE
  CAN
  JAR
  TIN
  CARTON
}

// Admin-defined stock units. Rows are paired with an ALTER TYPE
// "StockUnit" ADD VALUE at creation time so the enum accepts the value.
// Soft-delete hides the unit from dropdowns without touching the enum
// (Postgres can't drop enum values safely once in use).
model CustomUnit {
  id        String    @id @default(cuid())
  branchId  String
  code      String    // stored uppercase, must also be present in the StockUnit enum
  label     String    // display name
  createdAt DateTime  @default(now())
  deletedAt DateTime?

  branch Branch @relation(fields: [branchId], references: [id])

  @@unique([branchId, code])
  @@map("custom_units")
}

model Supplier {
  id          String    @id @default(cuid())
  branchId    String
  name        String
  contactName String?
  phone       String?
  email       String?
  address     String?
  notes       String?
  category       SupplierCategory @default(GENERAL)
  openingBalance Decimal          @default(0) @db.Decimal(14, 2)
  totalDue       Decimal          @default(0) @db.Decimal(14, 2)
  isActive    Boolean   @default(true)
  visibleToCashier Boolean @default(false)  // Phase 7: show this supplier in POS purchasing
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  // Relations
  branch              Branch              @relation(fields: [branchId], references: [id])
  ingredients         Ingredient[]
  ingredientSuppliers IngredientSupplier[]
  purchaseOrders      PurchaseOrder[]
  payments            SupplierPayment[]
  returns             PurchaseReturn[]

  @@index([branchId, isActive])
  @@map("suppliers")
}

model SupplierPayment {
  id              String        @id @default(cuid())
  branchId        String
  supplierId      String
  purchaseOrderId String?
  amount          Decimal       @db.Decimal(14, 2)
  paymentMethod   String        @default("CASH")
  reference       String?
  notes           String?
  paidById        String
  createdAt       DateTime      @default(now())

  // Relations
  branch        Branch         @relation(fields: [branchId], references: [id])
  supplier      Supplier       @relation(fields: [supplierId], references: [id])
  purchaseOrder PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  paidBy        Staff          @relation("SupplierPaymentBy", fields: [paidById], references: [id])

  @@index([branchId, supplierId])
  @@map("supplier_payments")
}

model Ingredient {
  id              String    @id @default(cuid())
  branchId        String
  supplierId      String?
  name            String
  itemCode        String?              // unique inventory code e.g. RAW-001
  category        IngredientCategory   @default(RAW)
  unit            StockUnit @default(G)                      // stock/recipe unit (G, ML, KG, etc.)
  purchaseUnit    String?                                    // supplier's selling unit (PACK, BOTTLE, BOX, BAG, etc.)
  purchaseUnitQty Decimal   @default(1) @db.Decimal(14, 4)  // 1 purchaseUnit = X stock units (e.g., 1 PACK = 200 G)
  currentStock    Decimal   @default(0) @db.Decimal(14, 4)  // in stock unit
  minimumStock    Decimal   @default(0) @db.Decimal(14, 4)
  costPerUnit     Decimal   @default(0) @db.Decimal(14, 4)  // cost in paisa per STOCK unit
  costPerPurchaseUnit Decimal @default(0) @db.Decimal(14, 4) // cost in paisa per PURCHASE unit
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  // ─── Variant Support ───
  parentId        String?                           // null = top-level (generic or standalone)
  hasVariants     Boolean   @default(false)         // true = parent with brand variants; stock lives on children
  brandName       String?                           // e.g. "Milk Butter", "Bread Pit"
  packSize        String?                           // e.g. "250G", "1L" — display label
  piecesPerPack   Int?                              // e.g. 10 pcs per pack
  sku             String?                           // supplier barcode / SKU
  // Website display
  imageUrl        String?                           // square image for website ingredient display
  showOnWebsite   Boolean   @default(true)          // show ingredient name on website menu detail pages

  // Relations
  branch             Branch              @relation(fields: [branchId], references: [id])
  supplier           Supplier?           @relation(fields: [supplierId], references: [id])
  suppliers          IngredientSupplier[]
  recipeItems        RecipeItem[]
  movements          StockMovement[]
  purchaseOrderItems PurchaseOrderItem[]
  wasteLogs          WasteLog[]
  preReadyRecipeItems PreReadyRecipeItem[]
  returnItems         PurchaseReturnItem[]
  parent             Ingredient?  @relation("IngredientVariants", fields: [parentId], references: [id])
  variants           Ingredient[] @relation("IngredientVariants")

  @@index([branchId, isActive])
  @@index([itemCode])
  @@index([parentId])
  @@map("ingredients")
}

model IngredientSupplier {
  id           String @id @default(cuid())
  ingredientId String
  supplierId   String

  // Relations
  ingredient Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  supplier   Supplier   @relation(fields: [supplierId], references: [id])

  @@unique([ingredientId, supplierId])
  @@map("ingredient_suppliers")
}

model Recipe {
  id         String   @id @default(cuid())
  menuItemId String   @unique
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  menuItem   MenuItem     @relation(fields: [menuItemId], references: [id])
  items      RecipeItem[]

  @@map("recipes")
}

model RecipeItem {
  id           String    @id @default(cuid())
  recipeId     String
  ingredientId String
  quantity     Decimal   @db.Decimal(14, 4)  // how much of the ingredient per 1 serving
  unit         StockUnit @default(G)         // unit of the quantity (may differ from ingredient's unit)

  // Relations
  recipe     Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredient Ingredient @relation(fields: [ingredientId], references: [id])

  @@unique([recipeId, ingredientId])
  @@map("recipe_items")
}

model StockMovement {
  id           String             @id @default(cuid())
  branchId     String
  ingredientId String
  type         StockMovementType
  quantity     Decimal            @db.Decimal(14, 4)  // positive = IN, negative = OUT
  notes        String?
  orderId      String?            // reference for SALE/VOID_RETURN movements
  staffId      String?            // who performed ADJUSTMENT/WASTE
  createdAt    DateTime           @default(now())

  // Relations
  branch     Branch     @relation(fields: [branchId], references: [id])
  ingredient Ingredient @relation(fields: [ingredientId], references: [id])

  @@index([branchId, createdAt])
  @@index([ingredientId])
  @@map("stock_movements")
}

// ─────────────────────────────────────────────────────────────────────────────
// PHASE 3 — PURCHASING
// ─────────────────────────────────────────────────────────────────────────────

enum PurchaseOrderStatus {
  DRAFT
  SENT
  PARTIAL
  RECEIVED
  CANCELLED
}

model PurchaseOrder {
  id          String              @id @default(cuid())
  branchId    String
  supplierId  String
  status      PurchaseOrderStatus @default(DRAFT)
  notes       String?
  orderedAt   DateTime?
  expectedAt  DateTime?
  receivedAt  DateTime?
  createdById String
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  deletedAt   DateTime?

  // Relations
  branch     Branch              @relation(fields: [branchId], references: [id])
  supplier   Supplier            @relation(fields: [supplierId], references: [id])
  createdBy         Staff               @relation("POCreatedBy", fields: [createdById], references: [id])
  items             PurchaseOrderItem[]
  supplierPayments  SupplierPayment[]
  returns           PurchaseReturn[]

  @@index([branchId, status])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id                String   @id @default(cuid())
  purchaseOrderId   String
  ingredientId      String
  unit              String?  // ordering unit (KG, PACK, etc.) — if null, use ingredient's purchaseUnit or unit
  quantityOrdered   Decimal  @db.Decimal(14, 4)
  quantityReceived  Decimal  @default(0) @db.Decimal(14, 4)
  unitCost          Decimal  @db.Decimal(14, 4)   // cost in paisa per unit
  makingDate        DateTime?  @db.Date
  expiryDate        DateTime?  @db.Date
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  ingredient    Ingredient    @relation(fields: [ingredientId], references: [id])

  @@map("purchase_order_items")
}

// ─────────────────────────────────────────────────────────────────────────────
// PHASE 6 — STAFF & PAYROLL
// ─────────────────────────────────────────────────────────────────────────────

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
  PAID_LEAVE
  SICK_LEAVE
  FESTIVAL_LEAVE
}

enum PayrollStatus {
  DRAFT
  APPROVED
  PAID
}

model Attendance {
  id        String           @id @default(cuid())
  branchId  String
  staffId   String
  date      DateTime         @db.Date
  clockIn   DateTime?
  clockOut  DateTime?
  status    AttendanceStatus @default(PRESENT)
  notes     String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  // Relations
  branch Branch @relation(fields: [branchId], references: [id])
  staff  Staff  @relation(fields: [staffId], references: [id])

  @@unique([staffId, date])
  @@index([branchId, date])
  @@map("attendance")
}

model Payroll {
  id            String        @id @default(cuid())
  branchId      String
  staffId       String
  periodStart   DateTime      @db.Date
  periodEnd     DateTime      @db.Date
  baseSalary    Decimal       @db.Decimal(14, 2)
  deductions    Decimal       @default(0) @db.Decimal(14, 2)
  bonuses       Decimal       @default(0) @db.Decimal(14, 2)
  netPayable    Decimal       @db.Decimal(14, 2)
  daysPresent   Int           @default(0)
  daysAbsent    Int           @default(0)
  status        PayrollStatus @default(DRAFT)
  notes         String?
  approvedById  String?
  approvedAt    DateTime?
  paidAt        DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  paidAmount  Decimal       @default(0) @db.Decimal(14, 2) // total paid so far

  // Relations
  branch     Branch           @relation(fields: [branchId], references: [id])
  staff      Staff            @relation(fields: [staffId], references: [id])
  approvedBy Staff?           @relation("PayrollApprover", fields: [approvedById], references: [id])
  payments   PayrollPayment[]

  @@index([branchId, periodStart])
  @@index([staffId])
  @@map("payrolls")
}

model PayrollPayment {
  id            String        @id @default(cuid())
  payrollId     String
  amount        Decimal       @db.Decimal(14, 2)
  paymentMethod String        @default("CASH")
  reference     String?
  notes         String?
  paidById      String
  createdAt     DateTime      @default(now())

  // Relations
  payroll Payroll @relation(fields: [payrollId], references: [id], onDelete: Cascade)
  paidBy  Staff   @relation("PayrollPaidBy", fields: [paidById], references: [id])

  @@index([payrollId])
  @@map("payroll_payments")
}

// ─────────────────────────────────────────────────────────────────────────────
// PHASE 7 — WASTE MANAGEMENT
// ─────────────────────────────────────────────────────────────────────────────

// ─────────────────────────────────────────────────────────────────────────────
// LEAVE MANAGEMENT
// ─────────────────────────────────────────────────────────────────────────────

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum LeaveType {
  SICK
  CASUAL
  ANNUAL
  UNPAID
  OTHER
}

model LeaveApplication {
  id           String      @id @default(cuid())
  branchId     String
  staffId      String
  type         LeaveType   @default(CASUAL)
  status       LeaveStatus @default(PENDING)
  startDate    DateTime    @db.Date
  endDate      DateTime    @db.Date
  reason       String?
  reviewedById String?
  reviewedAt   DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  // Relations
  branch     Branch @relation(fields: [branchId], references: [id])
  staff      Staff  @relation("LeaveApplicant", fields: [staffId], references: [id])
  reviewedBy Staff? @relation("LeaveReviewer", fields: [reviewedById], references: [id])

  @@index([branchId, staffId])
  @@map("leave_applications")
}

enum WasteReason {
  SPOILAGE
  PREPARATION_ERROR
  OVERCOOKED
  CONTAMINATION
  EXPIRED
  OTHER
}

model WasteLog {
  id           String      @id @default(cuid())
  branchId     String
  ingredientId String
  quantity     Decimal     @db.Decimal(14, 4)
  reason       WasteReason @default(OTHER)
  notes        String?
  recordedById String
  createdAt    DateTime    @default(now())

  // Relations
  branch     Branch     @relation(fields: [branchId], references: [id])
  ingredient Ingredient @relation(fields: [ingredientId], references: [id])
  recordedBy Staff      @relation("WasteRecorder", fields: [recordedById], references: [id])

  @@index([branchId, createdAt])
  @@index([ingredientId])
  @@map("waste_logs")
}

// ─────────────────────────────────────────────────────────────────────────────
// WORK PERIODS
// ─────────────────────────────────────────────────────────────────────────────

model WorkPeriod {
  id          String    @id @default(cuid())
  branchId    String
  startedAt   DateTime  @default(now())
  endedAt     DateTime?
  startedById String
  endedById   String?
  notes       String?
  openingCash Decimal   @default(0) @db.Decimal(14, 2)
  openingMFS  Decimal   @default(0) @db.Decimal(14, 2)
  openingCard Decimal   @default(0) @db.Decimal(14, 2)
  closingCash Decimal?  @db.Decimal(14, 2)
  closingMFS  Decimal?  @db.Decimal(14, 2)
  closingCard Decimal?  @db.Decimal(14, 2)
  balancesJson String?  // JSON: { opening: {accId: amount}, closing: {accId: amount} }
  createdAt   DateTime  @default(now())

  // Relations
  branch    Branch @relation(fields: [branchId], references: [id])
  startedBy Staff  @relation("WorkPeriodStarter", fields: [startedById], references: [id])
  endedBy   Staff? @relation("WorkPeriodEnder", fields: [endedById], references: [id])

  @@index([branchId, startedAt])
  @@map("work_periods")
}

// ─────────────────────────────────────────────────────────────────────────────
// COOKING STATIONS / MULTI-PRINTER
// ─────────────────────────────────────────────────────────────────────────────

model CookingStation {
  id          String   @id @default(cuid())
  branchId    String
  name        String
  // Printer target for this section's KOT. Leaving all three NULL means
  // the section falls back to the desktop's default kitchen slot.
  printerName String?   // Windows printer name (USB thermal driver) — os-printer mode
  printerIp   String?   // Network thermal printer host
  printerPort Int?      // Network thermal printer TCP port (default 9100 at runtime)
  // Per-section VAT opt-out. When false, items routed to this station are
  // excluded from the VAT base on new orders — useful for jurisdictions
  // that zero-rate certain categories (e.g. Bangladesh zero-rates some
  // beverages). The branch's master vatEnabled flag still wins: when VAT
  // is off branch-wide, no items are taxed regardless of section flags.
  vatEnabled  Boolean   @default(true)
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  branch    Branch     @relation(fields: [branchId], references: [id])
  menuItems MenuItem[]

  @@unique([branchId, name])
  @@map("cooking_stations")
}

// ─────────────────────────────────────────────────────────────────────────────
// UNIT CONVERSIONS
// ─────────────────────────────────────────────────────────────────────────────

model UnitConversion {
  id        String    @id @default(cuid())
  branchId  String
  fromUnit  StockUnit
  toUnit    StockUnit
  factor    Decimal   @db.Decimal(14, 6)  // 1 fromUnit = factor toUnits
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Relations
  branch Branch @relation(fields: [branchId], references: [id])

  @@unique([branchId, fromUnit, toUnit])
  @@map("unit_conversions")
}

// ─────────────────────────────────────────────────────────────────────────────
// PURCHASE RETURNS
// ─────────────────────────────────────────────────────────────────────────────

enum ReturnStatus {
  REQUESTED
  APPROVED
  COMPLETED
  REJECTED
}

model PurchaseReturn {
  id              String       @id @default(cuid())
  branchId        String
  purchaseOrderId String?
  supplierId      String
  status          ReturnStatus @default(REQUESTED)
  notes           String?
  requestedById   String
  completedAt     DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  // Relations
  branch        Branch              @relation(fields: [branchId], references: [id])
  purchaseOrder PurchaseOrder?      @relation(fields: [purchaseOrderId], references: [id])
  supplier      Supplier            @relation(fields: [supplierId], references: [id])
  requestedBy   Staff               @relation("ReturnRequester", fields: [requestedById], references: [id])
  items         PurchaseReturnItem[]

  @@index([branchId])
  @@map("purchase_returns")
}

model PurchaseReturnItem {
  id                String  @id @default(cuid())
  purchaseReturnId  String
  ingredientId      String
  quantity          Decimal @db.Decimal(14, 4)
  unitPrice         Decimal @db.Decimal(14, 4)

  // Relations
  purchaseReturn PurchaseReturn @relation(fields: [purchaseReturnId], references: [id], onDelete: Cascade)
  ingredient     Ingredient     @relation(fields: [ingredientId], references: [id])

  @@map("purchase_return_items")
}

// ─────────────────────────────────────────────────────────────────────────────
// BACKUP SYSTEM — OWNER-only database backups
// ─────────────────────────────────────────────────────────────────────────────

model BackupRecord {
  id         String   @id @default(cuid())
  filename   String
  fileUrl    String
  sizeBytes  Int
  type       String   @default("MANUAL") // MANUAL | AUTO
  createdAt  DateTime @default(now())
  createdById String?

  @@index([createdAt])
  @@map("backup_records")
}

model BackupSchedule {
  id        String    @id @default("default")
  frequency String    @default("OFF") // OFF | DAILY | WEEKLY | MONTHLY
  timeHour  Int       @default(2)     // 0-23, server local time
  retention Int       @default(10)    // keep N most recent AUTO backups
  lastRunAt DateTime?
  updatedAt DateTime  @updatedAt

  @@map("backup_schedule")
}

// ─────────────────────────────────────────────────────────────────────────────
// DESKTOP DEVICES — Paired Windows cashier terminals
// ─────────────────────────────────────────────────────────────────────────────
// Each installation of apps/pos-desktop registers itself once via POST
// /devices/register using owner credentials. Server returns a long-lived
// opaque device token; only its bcrypt hash is stored here. Desktop
// authenticates subsequent cashier logins by presenting the token.

model Device {
  id         String    @id @default(cuid())
  branchId   String
  name       String    // "Front Counter", "Register 2"
  tokenHash  String    // bcrypt hash of the device token
  lastSeenAt DateTime?
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  revokedAt  DateTime?
  createdById String?  // Staff.id of the owner/manager who paired the device

  branch Branch @relation(fields: [branchId], references: [id])

  @@index([branchId, isActive])
  @@map("devices")
}

// ─────────────────────────────────────────────────────────────────────────────
// IDEMPOTENCY — safe retries for mutation endpoints
// ─────────────────────────────────────────────────────────────────────────────
// Desktop terminals attach an Idempotency-Key header to every mutating
// request. If the network hiccups mid-drain and the same request replays,
// the server returns the cached response instead of executing twice.

model IdempotencyRecord {
  key          String   @id
  method       String
  path         String
  responseCode Int
  responseBody String   // JSON-serialized body
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@map("idempotency_records")
}

// ─────────────────────────────────────────────────────────────────────────────
// MUSHAK — Bangladesh NBR VAT compliance (6.3 invoices + 6.8 credit/debit notes)
// ─────────────────────────────────────────────────────────────────────────────
// Every paid order on a branch with `nbrEnabled=true` gets a MushakInvoice
// (form 6.3) with a per-branch, per-fiscal-year sequential serial. Refunds
// emit a MushakNote (form 6.8) linked to the original invoice. Both carry a
// frozen `snapshot` JSON so re-prints stay legally stable even after menu
// prices or VAT rates change later. The sequence table is upserted atomically
// inside the same transaction that writes the invoice/note, so concurrent
// terminals can't reuse or skip a seq.

model MushakSequence {
  id          String   @id @default(cuid())
  branchId    String
  fiscalYear  String // "2526" for BD FY Jul-2025 → Jun-2026
  docKind     String // "INVOICE" (6.3) or "NOTE" (6.8) — separate counters
  lastSeq     Int      @default(0)
  updatedAt   DateTime @updatedAt

  branch Branch @relation(fields: [branchId], references: [id])

  @@unique([branchId, fiscalYear, docKind])
  @@map("mushak_sequences")
}

model MushakInvoice {
  id               String   @id @default(cuid())
  branchId         String
  orderId          String   @unique
  serial           String   @unique // e.g. "2526/DHK/000147"
  fiscalYear       String
  branchCode       String
  seq              Int
  formVersion      String   @default("6.3")
  issuedAt         DateTime @default(now())
  // Buyer block — denormalised from Customer at issue time so later edits
  // to the customer record don't mutate the invoice.
  buyerName        String?
  buyerPhone       String?
  buyerAddress     String?
  buyerBin         String?
  // Frozen totals (decimals mirror Order). All values are post-discount,
  // pre-VAT subtotal + VAT breakdown so the PDF can be rebuilt verbatim.
  subtotalExclVat  Decimal  @db.Decimal(14, 2)
  sdAmount         Decimal  @default(0) @db.Decimal(14, 2)
  vatAmount        Decimal  @db.Decimal(14, 2)
  totalInclVat     Decimal  @db.Decimal(14, 2)
  // Full frozen JSON: seller block, buyer, every line with qty/rate/VAT/SD,
  // totals, timestamps, cashier name. Used by the reprint template — never
  // re-computed from live order data.
  snapshot         Json
  createdAt        DateTime @default(now())

  branch Branch      @relation(fields: [branchId], references: [id])
  order  Order       @relation(fields: [orderId], references: [id])
  notes  MushakNote[]

  @@unique([branchId, fiscalYear, seq])
  @@index([branchId, issuedAt])
  @@map("mushak_invoices")
}

model MushakNote {
  id               String          @id @default(cuid())
  branchId         String
  invoiceId        String
  orderId          String
  serial           String          @unique // e.g. "2526/DHK/NOTE/000023"
  fiscalYear       String
  branchCode       String
  seq              Int
  formVersion      String          @default("6.8")
  noteType         MushakNoteType
  reasonCode       RefundReason
  reasonText       String?
  issuedAt         DateTime        @default(now())
  issuedById       String
  // Refund totals — negative for CREDIT notes (refund), positive for DEBIT.
  subtotalExclVat  Decimal         @db.Decimal(14, 2)
  sdAmount         Decimal         @default(0) @db.Decimal(14, 2)
  vatAmount        Decimal         @db.Decimal(14, 2)
  totalInclVat     Decimal         @db.Decimal(14, 2)
  // JSON array of OrderItem ids actually refunded (empty when full-order).
  refundedItemIds  Json
  // Frozen JSON mirroring MushakInvoice.snapshot — used for slip reprint.
  snapshot         Json
  createdAt        DateTime        @default(now())

  branch   Branch        @relation(fields: [branchId], references: [id])
  invoice  MushakInvoice @relation(fields: [invoiceId], references: [id])
  order    Order         @relation(fields: [orderId], references: [id])
  issuedBy Staff         @relation("MushakNoteIssuer", fields: [issuedById], references: [id])

  @@unique([branchId, fiscalYear, seq])
  @@index([branchId, issuedAt])
  @@index([invoiceId])
  @@map("mushak_notes")
}

// (License / SystemConfig / UpdateRecord models are codecanyon-only and
// intentionally stripped on main.)
// ─── SMS ──────────────────────────────────────────────────────────────────────
// Log of every SMS attempt — outbound campaigns, payment receipts, OTPs that
// the admin cares about seeing. request_id comes from api.sms.net.bd and is
// used later to poll the status endpoint. `status` starts as QUEUED, flips to
// SENT when the gateway accepts, then DELIVERED / FAILED / EXPIRED based on
// the periodic poll. Retry support: set status back to QUEUED + clear
// requestId + bump attempts.
enum SmsStatus {
  QUEUED
  SENT
  DELIVERED
  FAILED
  EXPIRED
}

enum SmsKind {
  CAMPAIGN
  PAYMENT
  RESERVATION
  OTP
  OTHER
}

model SmsLog {
  id          String    @id @default(cuid())
  branchId    String
  toPhone     String
  body        String    @db.Text
  kind        SmsKind   @default(OTHER)
  status      SmsStatus @default(QUEUED)
  requestId   String?   // api.sms.net.bd request_id — poll key
  errorText   String?   // last error from gateway, if any
  attempts    Int       @default(1)
  // Optional joins — which customer / order / campaign prompted this send.
  customerId  String?
  orderId     String?
  campaignId  String?   // free-form — groups rows sent by one bulk action
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lastChecked DateTime? // last time we polled the status endpoint

  @@index([branchId, createdAt])
  @@index([branchId, status])
  @@index([campaignId])
  @@map("sms_logs")
}

// Reusable SMS bodies for the admin campaign composer. Uses {{name}} and
// {{phone}} placeholders — {{name}} falls back to "Dear Customer" when the
// customer record has no name.
model SmsTemplate {
  id        String   @id @default(cuid())
  branchId  String
  name      String   // display name in the admin picker
  body      String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([branchId, name])
  @@index([branchId])
  @@map("sms_templates")
}
