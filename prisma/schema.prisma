// ─── Prisma Schema ────────────────────────────────────────────────────────────
// Phase 1: Core POS & Orders
// Database: PostgreSQL 15
// Monetary values: Decimal(14,2) stored as smallest unit (paisa)
// Quantities:      Decimal(14,4) for sub-gram/ml accuracy
// All tables use soft deletes (deletedAt) and audit fields

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────────────

enum UserRole {
  OWNER
  MANAGER
  CASHIER
  KITCHEN
  WAITER
  ADVISOR
}

enum OrderType {
  DINE_IN
  TAKEAWAY
  DELIVERY
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  SERVED
  PAID
  VOID
  REFUNDED
  PARTIALLY_REFUNDED
}

// ─────────────────────────────────────────────────────────────────────────────
// NBR (Bangladesh) MUSHAK VAT COMPLIANCE
// ─────────────────────────────────────────────────────────────────────────────

enum MushakNoteType {
  CREDIT // refund / return — negative totals, reverses a 6.3
  DEBIT  // supplementary charge — positive totals, adds to a 6.3
}

enum RefundReason {
  CUSTOMER_RETURN
  PRICING_ERROR
  DUPLICATE
  DAMAGED
  OTHER
}

// ─────────────────────────────────────────────────────────────────────────────
// PAYMENT METHODS — Two-level: Category → Options
// ─────────────────────────────────────────────────────────────────────────────

// Level 1: Payment Category (e.g., CASH, CARD, MFS, DIGITAL, FOOD_DELIVERY)
model PaymentMethodConfig {
  id        String   @id @default(cuid())
  branchId  String
  code      String // CASH, CARD, MFS, DIGITAL, FOOD_DELIVERY
  name      String // "Cash", "Card", "Mobile Banking", "Digital Payment", "Food Delivery"
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  // Relations
  branch  Branch          @relation(fields: [branchId], references: [id])
  options PaymentOption[]

  @@unique([branchId, code])
  @@index([branchId, isActive])
  @@map("payment_method_configs")
}

// Level 2: Payment Option (e.g., "City POS" under CARD, "bKash" under MFS)
model PaymentOption {
  id         String   @id @default(cuid())
  branchId   String
  categoryId String // links to PaymentMethodConfig
  code       String // CITY_POS, DBBL_POS, BKASH, NAGAD, FOOD_PANDA
  name       String // "City POS Machine", "bKash", "Food Panda"
  accountId  String? // linked Account for balance tracking
  isActive   Boolean  @default(true)
  isDefault  Boolean  @default(false) // default option in its category
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())

  // Relations
  branch   Branch              @relation(fields: [branchId], references: [id])
  category PaymentMethodConfig @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  account  Account?            @relation(fields: [accountId], references: [id])

  @@unique([branchId, code])
  @@index([branchId, categoryId, isActive])
  @@map("payment_options")
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  CLEANING
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  ARRIVED
  COMPLETED
  NO_SHOW
  CANCELLED
}

enum KitchenTicketStatus {
  NEW
  PENDING_APPROVAL
  ACKNOWLEDGED
  PREPARING
  DONE
  RECALLED
}

enum MenuItemType {
  FOOD
  BEVERAGE
  MODIFIER
}

enum DiscountType {
  FLAT
  PERCENTAGE
}

enum DiscountScope {
  ALL_ITEMS
  SPECIFIC_ITEMS
  ALL_EXCEPT
}

// ─────────────────────────────────────────────────────────────────────────────
// BRANCH
// ─────────────────────────────────────────────────────────────────────────────

model Branch {
  id                   String    @id @default(cuid())
  name                 String
  address              String
  phone                String
  email                String?
  currency             String    @default("BDT")
  timezone             String    @default("Asia/Dhaka")
  taxRate              Decimal   @default(0) @db.Decimal(5, 2) // percentage e.g. 15.00
  vatEnabled           Boolean   @default(true) // master toggle — when false, taxRate is ignored on new orders
  serviceChargeEnabled Boolean   @default(false) // adds a service charge line above VAT
  serviceChargeRate    Decimal   @default(0) @db.Decimal(5, 2) // percentage e.g. 10.00
  stockPricingMethod   String    @default("LAST_PURCHASE") // LAST_PURCHASE or WEIGHTED_AVERAGE
  // ── Branding ──
  logoUrl              String? // main brand logo (used in admin, web, and as POS fallback)
  posLogoUrl           String? // optional override for POS sidebar
  websiteTagline       String? // hero tagline for the public website
  billHeaderText       String? // optional header text rendered above items on bill/receipt
  billFooterText       String? // free text shown at bottom of bills/receipts (multi-line)
  bin                  String? // Bangladesh Business Identification Number, shown under phone
  mushakVersion        String? // e.g. "Mushak-6.3" — printed below BIN on paper bills
  // ── NBR / Mushak compliance ──
  // When nbrEnabled=true on payment, a MushakInvoice row is issued atomically
  // (one serial per paid order, format {FY}/{branchCode}/{6-digit seq}) and
  // refunds emit MushakNote (6.8). When false the POS behaves exactly like
  // pre-NBR — this keeps non-Bangladesh deployments untouched.
  nbrEnabled           Boolean   @default(false)
  branchCode           String? // e.g. "DHK"; required when nbrEnabled=true
  sellerLegalName      String? // legal business name; falls back to `name`
  sellerTradingName    String? // trading / brand name; falls back to `name`
  wifiPass             String? // guest Wi-Fi password, optionally printed on the bill
  wifiSsid             String? // guest Wi-Fi network name (SSID) — shown on QR gate page
  qrGateEnabled        Boolean   @default(false) // when true, QR ordering requires the client IP to match qrAllowedIps
  qrAllowedIps         String? // comma-separated IPs and CIDR blocks (e.g. "192.168.1.0/24,203.0.113.42")
  qrGateMessage        String? // optional instructions shown under Wi-Fi details on the gate page
  billLogoWidthPct     Int       @default(80) // how wide the logo prints on the receipt (% of 80mm paper)
  facebookUrl          String?
  instagramUrl         String?
  isActive             Boolean   @default(true)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  deletedAt            DateTime?

  // Relations
  staff               Staff[]
  tables              DiningTable[]
  categories          MenuCategory[]
  menuItems           MenuItem[]
  orders              Order[]
  suppliers           Supplier[]
  ingredients         Ingredient[]
  stockMovements      StockMovement[]
  purchaseOrders      PurchaseOrder[]
  attendance          Attendance[]
  payrolls            Payroll[]
  wasteLogs           WasteLog[]
  expenses            Expense[]
  accounts            Account[]
  accountTransactions AccountTransaction[]
  preReadyItems       PreReadyItem[]
  productionOrders    ProductionOrder[]
  preReadyBatches     PreReadyBatch[]
  supplierPayments    SupplierPayment[]
  supplierAdjustments SupplierAdjustment[]
  creditors           Creditor[]
  creditorBills       CreditorBill[]
  creditorPayments    CreditorPayment[]
  creditorAdjustments CreditorAdjustment[]
  leaveApplications   LeaveApplication[]
  workPeriods         WorkPeriod[]
  cookingStations     CookingStation[]
  unitConversions     UnitConversion[]
  customUnits         CustomUnit[]
  paymentMethods      PaymentMethodConfig[]
  paymentOptions      PaymentOption[]
  purchaseReturns     PurchaseReturn[]
  discounts           Discount[]
  coupons             Coupon[]
  customers           Customer[]
  reviews             Review[]
  reservations        Reservation[]
  settings            BranchSetting?
  websiteContent      WebsiteContent?
  devices             Device[]
  mushakSequences     MushakSequence[]
  mushakInvoices      MushakInvoice[]
  mushakNotes         MushakNote[]
  customRoles         CustomRole[]
  menuItemAddonGroups MenuItemAddonGroup[]
  scheduledFbPosts    ScheduledFbPost[]
  activityLogs        ActivityLog[]

  @@index([isActive])
  @@map("branches")
}

model BranchSetting {
  id                              String  @id @default(cuid())
  branchId                        String  @unique
  // SMS Gateway
  smsEnabled                      Boolean @default(false)
  smsApiKey                       String?
  smsApiUrl                       String  @default("https://api.sms.net.bd/sendsms")
  // Notification toggles
  notifyVoidOtp                   Boolean @default(true) // Send OTP to manager for void approval
  smsPaymentNotifyEnabled         Boolean @default(false) // Auto-send thank-you SMS to customer on order payment
  smsPaymentTemplate              String? // Payment SMS body; supports {{name}} + {{amount}} + {{method}} placeholders
  // Theming
  posTheme                        String  @default("sunrise") // built-in slug or custom slug
  websiteTheme                    String  @default("sunrise")
  customThemes                    String? // JSON array of custom theme objects (slug, name, scope, tokens)
  // Cashier permissions (Phase 6)
  cashierPermissions              String? // JSON: per-action enabled+approval mode
  // Kitchen
  useKds                          Boolean @default(true) // When false, kitchen tickets auto-print from POS (no KDS screen)
  // ── Reservation Settings ──
  openingTime                     String  @default("09:00")
  closingTime                     String  @default("23:00")
  reservationSlotMinutes          Int     @default(90)
  reservationBlockMinutes         Int     @default(60)
  reservationMaxBookingsPerSlot   Int     @default(12)
  reservationMaxPersonsPerSlot    Int     @default(40)
  reservationAutoReserveMinutes   Int     @default(30)
  reservationLateThresholdMinutes Int     @default(30)
  reservationSmsEnabled           Boolean @default(true)
  reservationReminderMinutes      Int     @default(60)
  reservationSmsConfirmTemplate   String?
  reservationSmsRejectTemplate    String?
  reservationSmsReminderTemplate  String?
  reservationTermsOfService       String?
  /// % markup over recipe COGS for POS Customised Menu items.
  /// 52 means selling price floor = cost × 1.52.
  /// Null = no enforced floor (legacy behaviour).
  customMenuCostMargin       Decimal? @db.Decimal(5, 2)
  /// Optional downward room from the calculated floor (10 = cashier may
  /// negotiate up to 10% below). Null / 0 = price is locked at the floor.
  customMenuNegotiateMargin  Decimal? @db.Decimal(5, 2)
  /// Optional upward ceiling expressed as % markup over cost (200 = max
  /// 200% over cost). Null = no cap.
  customMenuMaxMargin        Decimal? @db.Decimal(5, 2)
  /// Allow QR-app customers to remove ingredients themselves ("no
  /// garlic"). When false (default), the QR app shows only the
  /// "Special note" field — cashier reads the note and applies the
  /// removal manually via the existing POS Customise dialog at order
  /// acceptance time.
  qrAllowSelfRemoveIngredients Boolean @default(false)
  /// Table-status timer thresholds in minutes. Order placed → kitchen
  /// Start (default 30); Start → kitchen Done (40); Served → cleared
  /// (35). Each phase clock starts fresh from the previous phase's
  /// transition timestamp. Null = use defaults.
  tableTimerOrderToStartMin  Int? @default(30)
  tableTimerStartToDoneMin   Int? @default(40)
  tableTimerServedToClearMin Int? @default(35)

  /// Lookback window (days) for the auto-min-stock recompute. When 0
  /// (default) the feature is OFF — minimum stock stays whatever
  /// admin manually set. When > 0, the nightly cron + the manual
  /// "Recompute Min Stock" button both rewrite each ingredient's
  /// minimumStock to the total quantity consumed (SALE +
  /// OPERATIONAL_USE movements) over the last N days. Per-row
  /// `Ingredient.autoMinStock` opts an individual ingredient out of
  /// the rewrite.
  autoMinStockDays           Int       @default(0)

  // ── Tipsoi attendance integration (Phase: HR) ──
  /// When true, hourly cron pulls Tipsoi /api/v1/logs and writes
  /// Attendance rows. Default off — existing branches keep their
  /// manual flow until admin opts in.
  tipsoiEnabled              Boolean   @default(false)
  /// Tipsoi API token. Plain text (same convention as smsApiKey on
  /// this same model). Masked in non-OWNER responses.
  tipsoiApiToken             String?
  tipsoiApiUrl               String    @default("https://api-inovace360.com")
  tipsoiLastSyncAt           DateTime?
  /// Last sync outcome: "OK" or "ERROR: <message>". Surfaced in the
  /// HR Settings tab so admin can spot a bad token.
  tipsoiLastSyncStatus       String?
  /// Branch default shift in HH:mm 24h. Per-staff overrides on Staff
  /// take precedence. Defaults reflect a typical 10am–10pm restaurant.
  attendanceShiftStart       String    @default("10:00")
  attendanceShiftEnd         String    @default("22:00")
  /// Minutes after shiftStart before a clock-in is counted as LATE.
  attendanceLateGraceMinutes Int       @default(30)
  /// Minutes after shiftStart before a clock-in is counted as HALF_DAY
  /// (i.e. the cutoff between LATE and HALF_DAY). Default 180 = 3h.
  attendanceHalfDayAfterMinutes Int    @default(180)

  /// Facebook auto-post integration. When `fbAutopostEnabled = true`
  /// and a `fbPageAccessToken` is set, every menu discount created on
  /// this branch spawns a scheduled FB post. Default off so existing
  /// branches don't change behaviour until admin opts in.
  fbAutopostEnabled  Boolean   @default(false)
  fbPageId           String?
  fbPageName         String?
  /// Long-lived page access token. Write-only via the Settings UI;
  /// `getSettings` masks it for non-OWNER reads (same convention as
  /// `smsApiKey` + `tipsoiApiToken`).
  fbPageAccessToken  String?
  fbConnectedAt      DateTime?
  /// Default time-of-day to roll midnight-startDate discounts forward
  /// to (so we don't all post at 00:00). Format "HH:mm".
  fbDefaultPostTime  String    @default("11:00")
  /// Optional custom caption template. Null falls back to the
  /// hard-coded default in apps/api/src/social/caption.ts. Supports
  /// the same {PLACEHOLDER} substitutions documented in that file.
  fbCaptionTemplate  String?   @db.Text

  /// WhatsApp Cloud API integration for sending Purchase Order PDFs to
  /// suppliers. Off by default; the "Send via WhatsApp" button on PO
  /// detail is hidden until enabled AND all three credential fields
  /// are populated. Token plaintext mirrors smsApiKey/tipsoiApiToken
  /// — masked in non-OWNER reads, stripped from activity-log diffs
  /// via SENSITIVE_FIELDS.
  whatsappEnabled         Boolean @default(false)
  whatsappPhoneNumberId   String?
  whatsappWabaId          String?
  whatsappAccessToken     String?
  whatsappPoTemplate      String  @default("purchase_order_v1")
  whatsappPoTemplateLang  String  @default("en_US")

  branch Branch @relation(fields: [branchId], references: [id])

  @@map("branch_settings")
}

// ─── Website CMS (Phase 5) ───────────────────────────────────────────────────
model WebsiteContent {
  id                        String   @id @default(cuid())
  branchId                  String   @unique
  // Hero
  heroTitle                 String   @default("Welcome")
  heroSubtitle              String?
  heroImageUrl              String?
  heroVideoUrl              String? // MP4 URL for hero background video
  heroCtaText               String   @default("View Menu")
  // About
  aboutTitle                String   @default("About Us")
  aboutBody                 String   @default("")
  aboutImageUrl             String?
  aboutPoint1               String? // numbered about card 1
  aboutPoint2               String?
  aboutPoint3               String?
  aboutPoint4               String?
  openingHours              String? // "Daily 11:00 - 23:00"
  // Contact
  contactNote               String?
  mapEmbedUrl               String?
  // Featured menu (JSON array of MenuCategory ids)
  featuredCategoryIds       String?
  // Section visibility toggles
  showReservation           Boolean  @default(true)
  showReviews               Boolean  @default(true)
  showGallery               Boolean  @default(true)
  showKeyIngredients        Boolean  @default(true)
  showPieces                Boolean  @default(true)
  showPrepTime              Boolean  @default(true)
  showSpiceLevel            Boolean  @default(true)
  showDeals                 Boolean  @default(true)
  showChefsSpecial          Boolean  @default(true)
  // Gallery
  galleryImages             String? // JSON array of image URLs
  // Section backgrounds (admin uploads image/video)
  menuSectionBg             String?
  aboutSectionBg            String?
  reviewsSectionBg          String?
  reservationSectionBg      String?
  contactSectionBg          String?
  bannerBg                  String? // full-width banner image
  bannerText                String? // banner large text
  // Theme & Colors
  websiteMode               String   @default("dark") // "dark" | "light"
  maintenanceMode           Boolean  @default(false) // when true, website shows maintenance page
  maintenanceBg             String? // background image for maintenance page
  maintenanceText           String? // custom maintenance text
  notFoundBg                String? // background image for 404 page
  notFoundText              String? // custom 404 text
  // SEO — Global
  seoSiteName               String? // e.g. "Your Restaurant"
  seoHomeTitle              String? // Home page title tag
  seoHomeDescription        String? // Home page meta description
  seoHomeKeywords           String? // comma-separated keywords
  seoMenuTitle              String? // Menu page title
  seoMenuDescription        String?
  seoAboutTitle             String?
  seoAboutDescription       String?
  seoContactTitle           String?
  seoContactDescription     String?
  seoReservationTitle       String?
  seoReservationDescription String?
  seoOgImage                String? // default Open Graph image
  seoFavicon                String? // favicon URL
  // Marketing tags injected into the public website's <head> at runtime.
  // Admin pastes the raw ID (not the whole snippet) and the web app
  // injects the standard loader script + noscript fallback.
  fbPixelId                 String? // Facebook Pixel ID, e.g. "123456789012345"
  googleAnalyticsId         String? // GA4 Measurement ID ("G-XXXXXXXXXX") or GTM container ("GTM-XXXXXX")
  accentColor               String   @default("#D62B2B")
  buttonColor               String   @default("#D62B2B")
  textColor                 String? // override (null = mode default)
  bgColor                   String? // override (null = mode default)
  // Menu visibility
  recommendedTag            String   @default("Chef Special")
  hiddenCategoryIds         String? // JSON array of category IDs
  hiddenItemIds             String? // JSON array of item IDs
  //
  updatedAt                 DateTime @updatedAt

  branch Branch @relation(fields: [branchId], references: [id])

  @@map("website_content")
}

// ─────────────────────────────────────────────────────────────────────────────
// STAFF
// ─────────────────────────────────────────────────────────────────────────────

model Staff {
  id            String    @id @default(cuid())
  branchId      String
  name          String
  email         String    @unique
  passwordHash  String
  phone         String?
  role          UserRole  @default(CASHIER)
  // Optional per-branch custom role overlay. The `role` column above is the
  // SECURITY anchor — all @Roles() guards + JWT checks run against it. The
  // custom role (if set) is a labelling + navigation-override layer on top;
  // it can only HIDE admin pages the base role would otherwise see and /
  // or tighten the POS cashier-ops matrix per role. It never elevates.
  customRoleId  String?
  isActive      Boolean   @default(true)
  // Whether this user can sign into a POS terminal (desktop lock-screen
  // tile + web POS login). Admin can flip off for roles that shouldn't
  // be operating a register (e.g. an ADVISOR who only needs admin).
  // OWNER/MANAGER are treated as always-allowed at the gate regardless.
  canAccessPos  Boolean   @default(true)
  hireDate      DateTime  @default(now())
  monthlySalary Decimal?  @db.Decimal(14, 2)
  /// Tipsoi `person_identifier` (e.g. "Ahmed-1234"). Optional — Owner
  /// / Advisor roles that don't clock in don't need a device account.
  /// Sync drops logs whose person_identifier doesn't map here.
  tipsoiPersonId        String?
  /// Per-staff shift overrides in HH:mm 24h, branch local time. Null
  /// → falls back to BranchSetting.attendanceShiftStart / shiftEnd.
  /// shiftEnd may cross midnight (e.g. 15:00 → 01:00 for a bar shift).
  shiftStart            String?
  shiftEnd              String?
  /// Per-staff late + half-day overrides in minutes after shiftStart.
  /// Null → falls back to BranchSetting.attendanceLateGraceMinutes /
  /// attendanceHalfDayAfterMinutes.
  lateGraceMinutes      Int?
  halfDayAfterMinutes   Int?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  // Relations
  branch                    Branch             @relation(fields: [branchId], references: [id])
  ordersAsCashier           Order[]            @relation("OrderCashier")
  voidedOrders              Order[]            @relation("OrderVoidedBy")
  purchaseOrdersCreated     PurchaseOrder[]    @relation("POCreatedBy")
  attendance                Attendance[]
  payrolls                  Payroll[]
  payrollsApproved          Payroll[]          @relation("PayrollApprover")
  payrollPayments           PayrollPayment[]   @relation("PayrollPaidBy")
  wasteLogsRecorded         WasteLog[]         @relation("WasteRecorder")
  expensesRecorded          Expense[]          @relation("ExpenseRecordedBy")
  expensesApproved          Expense[]          @relation("ExpenseApprover")
  productionOrdersRequested ProductionOrder[]  @relation("ProductionRequester")
  productionOrdersApproved  ProductionOrder[]  @relation("ProductionApprover")
  supplierPayments          SupplierPayment[]  @relation("SupplierPaymentBy")
  supplierAdjustments       SupplierAdjustment[] @relation("SupplierAdjustmentBy")
  creditorBills             CreditorBill[]     @relation("CreditorBillBy")
  creditorPayments          CreditorPayment[]  @relation("CreditorPaymentBy")
  creditorAdjustments       CreditorAdjustment[] @relation("CreditorAdjustmentBy")
  leaveApplications         LeaveApplication[] @relation("LeaveApplicant")
  leaveReviews              LeaveApplication[] @relation("LeaveReviewer")
  workPeriodsStarted        WorkPeriod[]       @relation("WorkPeriodStarter")
  workPeriodsEnded          WorkPeriod[]       @relation("WorkPeriodEnder")
  ordersAsWaiter            Order[]            @relation("OrderWaiter")
  returnsRequested          PurchaseReturn[]   @relation("ReturnRequester")
  reservationsConfirmed     Reservation[]      @relation("ReservationConfirmer")
  mushakNotesIssued         MushakNote[]       @relation("MushakNoteIssuer")
  customRole                CustomRole?        @relation(fields: [customRoleId], references: [id])
  activityLogs              ActivityLog[]

  @@index([branchId, isActive])
  @@index([email])
  @@map("staff")
}

// ─────────────────────────────────────────────────────────────────────────────
// CUSTOM ROLES — admin-configurable permission presets
// ─────────────────────────────────────────────────────────────────────────────
// A custom role is a labelled permission preset attached on top of a staff
// member's required base `UserRole`. Security is always enforced by the
// base role (JWT + @Roles() guards are unchanged). The custom role only:
//   1. Hides admin nav items the base role would otherwise see (via
//      adminNavOverrides — a map of { [navPath]: boolean } where `false`
//      hides the item).
//   2. Overrides the POS cashier-ops matrix per role (via posPermissions —
//      same shape as BranchSetting.cashierPermissions), applied on top of
//      the branch default inside permissions.service.requirePermission().
//
// Can never elevate — service + UI both reject overrides that would reveal
// pages / actions the base role isn't already allowed to reach. Per-branch
// scope to match how BranchSetting.cashierPermissions is already modelled.

model CustomRole {
  id                String    @id @default(cuid())
  branchId          String
  name              String // display label, e.g. "Head Chef"
  description       String?
  // The SECURITY anchor — JWT still carries this exact enum value and
  // every @Roles() guard checks against it. Custom role inherits from this.
  baseRole          UserRole
  // Nav overrides — JSON { [navPath]: boolean }. A missing key means
  // "defer to the base role's allowedRoles check". An explicit `false`
  // hides the item for staff assigned to this custom role.
  adminNavOverrides Json?
  // POS cashier-ops overrides — mirrors CashierPermissions shape. Only
  // consulted when baseRole ∈ { CASHIER, ADVISOR, WAITER }.
  posPermissions    Json?
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  branch Branch  @relation(fields: [branchId], references: [id])
  staff  Staff[]

  @@unique([branchId, name])
  @@index([branchId])
  @@map("custom_roles")
}

// ─────────────────────────────────────────────────────────────────────────────
// DINING TABLES
// ─────────────────────────────────────────────────────────────────────────────

model DiningTable {
  id          String      @id @default(cuid())
  branchId    String
  tableNumber String
  capacity    Int         @default(4)
  status      TableStatus @default(AVAILABLE)
  floorPlanX  Float?
  floorPlanY  Float?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  deletedAt   DateTime?

  // Relations
  branch       Branch        @relation(fields: [branchId], references: [id])
  orders       Order[]
  reservations Reservation[]

  @@unique([branchId, tableNumber])
  @@index([branchId, status])
  @@map("dining_tables")
}

// ─────────────────────────────────────────────────────────────────────────────
// MENU
// ─────────────────────────────────────────────────────────────────────────────

model MenuCategory {
  id        String    @id @default(cuid())
  branchId  String
  parentId  String?
  name      String
  slug      String? // SEO-friendly URL slug (auto-generated from name)
  icon      String? // emoji or icon name (e.g. "🍗", "🍕", "☕")
  sortOrder Int       @default(0)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  websiteVisible Boolean @default(true) // hide entire category from public website

  // Relations
  branch    Branch         @relation(fields: [branchId], references: [id])
  parent    MenuCategory?  @relation("CategoryParent", fields: [parentId], references: [id])
  children  MenuCategory[] @relation("CategoryParent")
  menuItems MenuItem[]

  @@index([branchId, sortOrder])
  @@map("menu_categories")
}

model MenuItem {
  id             String       @id @default(cuid())
  branchId       String
  categoryId     String
  name           String
  slug           String? // SEO-friendly URL slug
  seoTitle       String? // custom SEO title for this item
  seoDescription String? // custom meta description
  description    String?
  type           MenuItemType @default(FOOD)
  price          Decimal      @db.Decimal(14, 2) // stored in paisa
  costPrice      Decimal?     @db.Decimal(14, 2)
  imageUrl       String?
  tags           String? // comma-separated: "vegan,spicy,nut-free,chicken"
  isAvailable    Boolean      @default(true)
  sortOrder      Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  isCombo          Boolean @default(false)
  cookingStationId String?
  // Website detail fields
  pieces           String? // e.g. "4-6" — null = don't show
  prepTime         String? // e.g. "15 min"
  spiceLevel       String? // e.g. "Mild", "Medium", "Hot"
  websiteVisible   Boolean @default(true) // hide from website without affecting POS
  /// True for items created via POS Customised Menu. UI uses this to
  /// hide them from the admin Menu page filter and to bypass website /
  /// QR feeds (websiteVisible=false handles the latter; this is the
  /// explicit provenance flag).
  isCustom         Boolean @default(false)
  /// Nullable parent FK. When set, this row is a sellable variant
  /// (e.g. "Hargao Prawn") and `variantParent` is the picker shell
  /// (e.g. "Hargao"). When null, item is either a standalone sellable
  /// item (legacy behaviour) or itself a parent shell when
  /// `isVariantParent=true`. Variants are limited to ONE level deep —
  /// admin / API enforce.
  variantParentId  String?
  /// True when this item is a non-sellable picker shell that exists
  /// only to group its variants. POS picker shows it as a card; click
  /// opens the variant chooser. Server rejects orderItem.create against
  /// a parent shell. Legacy MenuItems all have isVariantParent=false.
  isVariantParent  Boolean @default(false)
  /// True when this row is an addon (Extra Patty, Cheese Sauce,
  /// Garlic Nun, etc). Filtered out of the main POS grid + the
  /// website / QR feed; selectable only via an addon group on a
  /// parent menu item. Reuses the existing price + recipe shape so
  /// reports / costing engines work without modification.
  isAddon          Boolean @default(false)

  // Relations
  branch           Branch                @relation(fields: [branchId], references: [id])
  category         MenuCategory          @relation(fields: [categoryId], references: [id])
  cookingStation   CookingStation?       @relation(fields: [cookingStationId], references: [id])
  orderItems       OrderItem[]
  recipe           Recipe?
  comboItems       ComboItem[]           @relation("ComboMenu")
  includedInCombos ComboItem[]           @relation("ComboIncluded")
  linkedItems      LinkedItem[]          @relation("LinkedParent")
  linkedFrom       LinkedItem[]          @relation("LinkedChild")
  menuDiscounts    MenuItemDiscount[]
  variantParent    MenuItem?             @relation("MenuVariants", fields: [variantParentId], references: [id])
  variants         MenuItem[]            @relation("MenuVariants")
  /// Addon groups attached to this menu item (the parent dish offers
  /// these picks at order time). Only populated on non-addon items.
  addonGroups      MenuItemAddonGroup[]
  /// Junction rows that point AT this menu item when it serves as an
  /// addon option. Inverse for MenuItemAddonOption.addon. Only
  /// populated when isAddon=true.
  addonOptionLinks MenuItemAddonOption[] @relation("MenuItemAddonChild")

  @@index([branchId, categoryId, isAvailable])
  @@index([branchId, sortOrder])
  @@map("menu_items")
}

// ─────────────────────────────────────────────────────────────────────────────
// MENU ADDONS (Phase 3)
// ─────────────────────────────────────────────────────────────────────────────

/// Group of addons offered on a parent menu item ("Sides", "Sauces").
/// minPicks=0 + maxPicks=N matches the "up to N, can skip" UX from the
/// product spec (e.g. up to 2 sides). Required groups set minPicks > 0.
model MenuItemAddonGroup {
  id          String                @id @default(cuid())
  branchId    String
  /// Parent menu item that offers this group.
  menuItemId  String
  name        String
  minPicks    Int                   @default(0)
  maxPicks    Int                   @default(1)
  sortOrder   Int                   @default(0)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  deletedAt   DateTime?

  branch      Branch                @relation(fields: [branchId], references: [id])
  menuItem    MenuItem              @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  options     MenuItemAddonOption[]

  @@index([menuItemId])
  @@map("menu_item_addon_groups")
}

/// Junction: which addon (a MenuItem with isAddon=true) is offered in
/// which group. Same addon can appear in many groups (e.g. Cheese Sauce
/// available on both Steak and Burger).
model MenuItemAddonOption {
  id          String             @id @default(cuid())
  groupId     String
  /// MenuItem.id of the addon (the row must have isAddon=true).
  addonItemId String
  sortOrder   Int                @default(0)

  group       MenuItemAddonGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  addon       MenuItem           @relation("MenuItemAddonChild", fields: [addonItemId], references: [id], onDelete: Cascade)

  @@unique([groupId, addonItemId])
  @@map("menu_item_addon_options")
}

// ─────────────────────────────────────────────────────────────────────────────
// COMBO & LINKED ITEMS
// ─────────────────────────────────────────────────────────────────────────────

model ComboItem {
  id             String @id @default(cuid())
  comboMenuId    String
  includedItemId String
  quantity       Int    @default(1)

  // Relations
  comboMenu    MenuItem @relation("ComboMenu", fields: [comboMenuId], references: [id], onDelete: Cascade)
  includedItem MenuItem @relation("ComboIncluded", fields: [includedItemId], references: [id])

  @@unique([comboMenuId, includedItemId])
  @@map("combo_items")
}

enum LinkedItemType {
  FREE
  COMPLEMENTARY
}

model LinkedItem {
  id              String         @id @default(cuid())
  parentMenuId    String
  linkedMenuId    String
  type            LinkedItemType @default(FREE)
  triggerQuantity Int            @default(1)
  freeQuantity    Int            @default(1)

  // Relations
  parentMenu MenuItem @relation("LinkedParent", fields: [parentMenuId], references: [id], onDelete: Cascade)
  linkedMenu MenuItem @relation("LinkedChild", fields: [linkedMenuId], references: [id])

  @@unique([parentMenuId, linkedMenuId])
  @@map("linked_items")
}

// ─────────────────────────────────────────────────────────────────────────────
// CUSTOMERS
// ─────────────────────────────────────────────────────────────────────────────

model Customer {
  id          String    @id @default(cuid())
  branchId    String
  phone       String
  name        String    @default("Walk-in")
  email       String?
  totalOrders Int       @default(0)
  totalSpent  Decimal   @default(0) @db.Decimal(14, 2)
  lastVisit   DateTime?
  agreedTerms Boolean   @default(true)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  branch       Branch        @relation(fields: [branchId], references: [id])
  orders       Order[]
  reviews      Review[]
  reservations Reservation[]

  @@unique([branchId, phone])
  @@index([branchId, phone])
  @@map("customers")
}

model Review {
  id              String   @id @default(cuid())
  branchId        String
  orderId         String   @unique
  customerId      String?
  foodScore       Int // 1-5
  serviceScore    Int // 1-5
  atmosphereScore Int // 1-5
  priceScore      Int // 1-5
  notes           String?
  createdAt       DateTime @default(now())

  branch   Branch    @relation(fields: [branchId], references: [id])
  order    Order     @relation(fields: [orderId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])

  @@index([branchId])
  @@map("reviews")
}

// ─────────────────────────────────────────────────────────────────────────────
// RESERVATIONS
// ─────────────────────────────────────────────────────────────────────────────

model Reservation {
  id             String            @id @default(cuid())
  branchId       String
  customerId     String?
  customerName   String
  customerPhone  String
  date           DateTime          @db.Date
  timeSlot       String // "HH:mm" start time
  partySize      Int
  status         ReservationStatus @default(PENDING)
  tableId        String?
  tableIds       String? // JSON array of table IDs for multi-table bookings
  notes          String?
  confirmedById  String?
  confirmedAt    DateTime?
  arrivedAt      DateTime?
  completedAt    DateTime?
  cancelledAt    DateTime?
  cancelReason   String?
  agreedTerms    Boolean           @default(true)
  reminderSentAt DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  branch      Branch       @relation(fields: [branchId], references: [id])
  customer    Customer?    @relation(fields: [customerId], references: [id])
  table       DiningTable? @relation(fields: [tableId], references: [id])
  confirmedBy Staff?       @relation("ReservationConfirmer", fields: [confirmedById], references: [id])

  @@index([branchId, date, status])
  @@index([branchId, status])
  @@index([customerPhone])
  @@map("reservations")
}

// ─────────────────────────────────────────────────────────────────────────────
// ORDERS
// ─────────────────────────────────────────────────────────────────────────────

model Order {
  id                  String      @id @default(cuid())
  orderNumber         String      @unique
  branchId            String
  cashierId           String
  tableId             String?
  tableNumber         String? // denormalized — survives table deletion
  type                OrderType   @default(DINE_IN)
  status              OrderStatus @default(PENDING)
  notes               String?
  subtotal            Decimal     @db.Decimal(14, 2)
  taxAmount           Decimal     @default(0) @db.Decimal(14, 2)
  serviceChargeAmount Decimal     @default(0) @db.Decimal(14, 2) // added before VAT when branch.serviceChargeEnabled
  discountAmount      Decimal     @default(0) @db.Decimal(14, 2)
  discountId          String? // applied Discount ID
  discountName        String? // denormalized discount/coupon display name
  couponId            String? // applied Coupon ID
  couponCode          String? // denormalized coupon code
  totalAmount         Decimal     @db.Decimal(14, 2)
  // Auto rounding to the nearest taka (100 paisa). Signed delta in paisa;
  // positive when the bill was rounded UP, negative when rounded DOWN.
  // totalAmount already includes this adjustment — receipts print an
  // "Auto Roundup (+0.30)" line below VAT to make the delta visible.
  roundAdjustment     Decimal     @default(0) @db.Decimal(14, 2)
  paymentMethod       String?
  paidAt              DateTime?
  customerId          String?
  customerName        String? // denormalized — "Walk-in" or customer name
  customerPhone       String? // denormalized
  waiterId            String?
  guestCount          Int         @default(0) // number of guests at the table (printed on bill/receipt)
  billRequested       Boolean     @default(false)
  /// First time any item on this order moved to PREPARING — drives the
  /// table-status "kitchen acked" timer on the POS Tables page.
  firstKitchenStartAt DateTime?
  /// First time the order's items reached DONE / READY — drives the
  /// "served, awaiting pay/clear" timer (last phase).
  firstKitchenDoneAt  DateTime?
  voidReason          String?
  voidedById          String?
  voidedAt            DateTime?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  deletedAt           DateTime?

  // Relations
  branch   Branch         @relation(fields: [branchId], references: [id])
  cashier  Staff          @relation("OrderCashier", fields: [cashierId], references: [id])
  table    DiningTable?   @relation(fields: [tableId], references: [id])
  customer Customer?      @relation(fields: [customerId], references: [id])
  review   Review?
  waiter   Staff?         @relation("OrderWaiter", fields: [waiterId], references: [id])
  voidedBy Staff?         @relation("OrderVoidedBy", fields: [voidedById], references: [id])
  items    OrderItem[]
  payments OrderPayment[]
  mushakInvoice MushakInvoice?
  mushakNotes   MushakNote[]

  @@index([branchId, status])
  @@index([branchId, createdAt])
  @@index([orderNumber])
  @@map("orders")
}

model OrderItem {
  id            String              @id @default(cuid())
  orderId       String
  menuItemId    String
  menuItemName  String // denormalized — survives menu item deletion
  quantity      Int
  unitPrice     Decimal             @db.Decimal(14, 2)
  totalPrice    Decimal             @db.Decimal(14, 2)
  notes         String?
  kitchenStatus KitchenTicketStatus @default(NEW)
  voidedAt      DateTime?
  voidReason    String?
  voidedById    String?
  /// Per-line modifications applied at order time. Shape:
  ///   { removedIngredientIds: string[], removedNames: string[] }
  /// Stock-deduction skips removed ingredient IDs; KT print prepends
  /// "— NO <NAME>" lines per removed ingredient. Null / empty = no
  /// mods (legacy behaviour). Cart key includes a hash of removedIds
  /// so 2× without garlic + 2× normal land on two separate OrderItem
  /// rows (and two separate KT entries).
  modifications Json?
  /// Per-line addon snapshot. Shape:
  ///   [{ groupId, groupName, addonItemId, addonName, price, recipeMenuItemId? }]
  /// Frozen at order time so a future menu edit doesn't rewrite history.
  /// Stock for each addon's recipe deducts on top of the base item's
  /// recipe; KT print + receipts itemize each pick under the base line.
  /// Cart key includes an addons hash so different selections become
  /// separate OrderItem rows.
  addons        Json?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  // Relations
  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem MenuItem @relation(fields: [menuItemId], references: [id])

  @@index([orderId])
  @@index([menuItemId])
  @@map("order_items")
}

model OrderPayment {
  id        String   @id @default(cuid())
  orderId   String
  method    String
  amount    Decimal  @db.Decimal(14, 2)
  reference String? // transaction ref for CARD/MFS
  createdAt DateTime @default(now())

  // Relations
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_payments")
}

// ─────────────────────────────────────────────────────────────────────────────
// DISCOUNTS & COUPONS
// ─────────────────────────────────────────────────────────────────────────────

model Discount {
  id          String        @id @default(cuid())
  branchId    String
  name        String
  type        DiscountType // FLAT or PERCENTAGE
  value       Decimal       @db.Decimal(14, 2) // paisa for FLAT, percentage for PERCENTAGE
  scope       DiscountScope @default(ALL_ITEMS)
  targetItems String? // JSON array of menuItemIds (for SPECIFIC_ITEMS / ALL_EXCEPT)
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  branch Branch @relation(fields: [branchId], references: [id])

  @@index([branchId, isActive])
  @@map("discounts")
}

model Coupon {
  id          String        @id @default(cuid())
  branchId    String
  code        String
  name        String
  type        DiscountType
  value       Decimal       @db.Decimal(14, 2)
  scope       DiscountScope @default(ALL_ITEMS)
  targetItems String?
  maxUses     Int           @default(0) // 0 = unlimited
  usedCount   Int           @default(0)
  expiresAt   DateTime?
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  branch Branch @relation(fields: [branchId], references: [id])

  @@unique([branchId, code])
  @@index([branchId, isActive])
  @@map("coupons")
}

model MenuItemDiscount {
  id             String       @id @default(cuid())
  menuItemId     String
  type           DiscountType
  value          Decimal      @db.Decimal(14, 2)
  startDate      DateTime
  endDate        DateTime
  applicableDays String? // JSON array like ["FRIDAY","SUNDAY"], null = all days
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  menuItem        MenuItem          @relation(fields: [menuItemId], references: [id])
  scheduledPosts  ScheduledFbPost[]

  @@index([menuItemId, isActive])
  @@map("menu_item_discounts")
}

/// Auto-Facebook-post queue. Each row represents one image+caption
/// scheduled to be posted to the branch's connected FB page. Lifecycle:
/// PENDING → POSTED on success, → FAILED after 3 failed cron attempts,
/// → CANCELLED when admin cancels. Reusable for non-discount manual
/// posts in v2 (menuDiscountId is nullable).
enum FbPostStatus {
  PENDING
  POSTED
  CANCELLED
  FAILED
}

model ScheduledFbPost {
  id             String       @id @default(cuid())
  branchId       String
  menuDiscountId String?
  status         FbPostStatus @default(PENDING)
  scheduledAt    DateTime
  postedAt       DateTime?
  /// FB returns post id on success — store for the "View on Facebook" link.
  fbPostId       String?
  message        String       @db.Text
  /// Either an absolute /uploads/... path (dev) or an S3/Spaces key (prod).
  imagePath      String
  attempts       Int          @default(0)
  lastError      String?      @db.Text
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  branch       Branch            @relation(fields: [branchId], references: [id])
  menuDiscount MenuItemDiscount? @relation(fields: [menuDiscountId], references: [id], onDelete: SetNull)

  @@index([branchId, status, scheduledAt])
  @@map("scheduled_fb_posts")
}

// ─────────────────────────────────────────────────────────────────────────────
// EXPENSE MANAGEMENT
// ─────────────────────────────────────────────────────────────────────────────

enum ExpenseCategory {
  RENT
  UTILITIES
  SALARY
  SUPPLIES
  MAINTENANCE
  TRANSPORT
  MARKETING
  FOOD_COST
  STAFF_FOOD
  MISCELLANEOUS
}

model Expense {
  id            String          @id @default(cuid())
  branchId      String
  category      ExpenseCategory @default(MISCELLANEOUS)
  description   String
  amount        Decimal         @db.Decimal(14, 2) // in paisa
  paymentMethod String          @default("CASH")
  reference     String?
  date          DateTime        @db.Date
  recordedById  String
  approvedById  String?
  approvedAt    DateTime?
  notes         String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  deletedAt     DateTime?

  // Relations
  branch     Branch @relation(fields: [branchId], references: [id])
  recordedBy Staff  @relation("ExpenseRecordedBy", fields: [recordedById], references: [id])
  approvedBy Staff? @relation("ExpenseApprover", fields: [approvedById], references: [id])

  @@index([branchId, date])
  @@index([branchId, category])
  @@map("expenses")
}

// ─────────────────────────────────────────────────────────────────────────────
// ACCOUNT MANAGEMENT
// ─────────────────────────────────────────────────────────────────────────────

enum AccountType {
  CASH
  BANK
  MFS
  POS_TERMINAL
}

model Account {
  id                  String      @id @default(cuid())
  branchId            String
  type                AccountType
  name                String // e.g. "Main Cash Register", "bKash", "Dutch-Bangla Bank"
  balance             Decimal     @default(0) @db.Decimal(14, 2)
  isActive            Boolean     @default(true)
  showInPOS           Boolean     @default(false) // show in POS opening/closing balance
  linkedPaymentMethod String? // CASH, MFS, CARD — links this account to a payment method
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  // Relations
  branch         Branch               @relation(fields: [branchId], references: [id])
  transactions   AccountTransaction[]
  paymentOptions PaymentOption[]

  @@unique([branchId, type, name])
  @@index([branchId, isActive])
  @@map("accounts")
}

enum TransactionType {
  SALE
  EXPENSE
  PURCHASE_PAYMENT
  TRANSFER
  ADJUSTMENT
}

model AccountTransaction {
  id          String          @id @default(cuid())
  branchId    String
  accountId   String
  type        TransactionType
  amount      Decimal         @db.Decimal(14, 2) // positive = IN, negative = OUT
  description String
  referenceId String? // orderId, expenseId, purchaseOrderId
  createdAt   DateTime        @default(now())

  // Relations
  branch  Branch  @relation(fields: [branchId], references: [id])
  account Account @relation(fields: [accountId], references: [id])

  @@index([branchId, createdAt])
  @@index([accountId])
  @@map("account_transactions")
}

// ─────────────────────────────────────────────────────────────────────────────
// PRE-READY FOODS
// ─────────────────────────────────────────────────────────────────────────────

enum ProductionStatus {
  PENDING // awaiting manager approval
  APPROVED // approved, ready to produce
  IN_PROGRESS // kitchen is making it
  COMPLETED // done, stock updated
  WASTED // produced but result was bad — ingredients deducted, no batch created
  CANCELLED
}

model PreReadyItem {
  id           String    @id @default(cuid())
  branchId     String
  name         String
  unit         StockUnit @default(PCS)
  currentStock Decimal   @default(0) @db.Decimal(14, 4)
  minimumStock Decimal   @default(0) @db.Decimal(14, 4)
  /// Auto-calculated cost per produced unit, derived from the item's
  /// recipe (sum of ingredient cost × deduct qty / yield). Refreshed by
  /// the Recalculate Cost button or whenever a production is completed.
  /// Stored in paisa.
  costPerUnit  Decimal   @default(0) @db.Decimal(14, 2)
  /// Optional pairing: when set, every completed production batch ALSO
  /// bumps the linked Ingredient's currentStock by the produced yield
  /// (in addition to PreReadyItem.currentStock), so menu recipes that
  /// reference the linked Ingredient deduct from the same single
  /// source of truth. Without this link, PreReadyItem and Ingredient
  /// counters drift permanently.
  producesIngredientId String?
  /// When true (default), production-completion auto-deducts the
  /// recipe's input ingredients from inventory. Some kitchens prefer
  /// to reconcile raw stock manually at end of week — opting out here
  /// keeps production tracked but skips the auto-deduction step.
  autoDeductInputs Boolean @default(true)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  // Relations
  branch              Branch            @relation(fields: [branchId], references: [id])
  recipe              PreReadyRecipe?
  productionOrders    ProductionOrder[]
  batches             PreReadyBatch[]
  producesIngredient  Ingredient?       @relation("PreReadyProducesIngredient", fields: [producesIngredientId], references: [id], onDelete: SetNull)

  @@index([branchId, isActive])
  @@map("pre_ready_items")
}

model PreReadyRecipe {
  id             String    @id @default(cuid())
  preReadyItemId String    @unique
  yieldQuantity  Decimal   @db.Decimal(14, 4) // how much 1 recipe produces (e.g. 1000 for 1L sauce)
  yieldUnit      StockUnit @default(G)
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  preReadyItem PreReadyItem         @relation(fields: [preReadyItemId], references: [id])
  items        PreReadyRecipeItem[]

  @@map("pre_ready_recipes")
}

model PreReadyRecipeItem {
  id           String    @id @default(cuid())
  recipeId     String
  ingredientId String
  quantity     Decimal   @db.Decimal(14, 4) // per 1 full recipe yield
  unit         StockUnit @default(G) // unit of the quantity (may differ from ingredient's unit)

  // Relations
  recipe     PreReadyRecipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredient Ingredient     @relation(fields: [ingredientId], references: [id])

  @@unique([recipeId, ingredientId])
  @@map("pre_ready_recipe_items")
}

model ProductionOrder {
  id             String           @id @default(cuid())
  branchId       String
  preReadyItemId String
  quantity       Decimal          @db.Decimal(14, 4) // how much to produce
  status         ProductionStatus @default(PENDING)
  requestedById  String
  approvedById   String?
  approvedAt     DateTime?
  completedAt    DateTime?
  notes          String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  // Relations
  branch       Branch       @relation(fields: [branchId], references: [id])
  preReadyItem PreReadyItem @relation(fields: [preReadyItemId], references: [id])
  requestedBy  Staff        @relation("ProductionRequester", fields: [requestedById], references: [id])
  approvedBy   Staff?       @relation("ProductionApprover", fields: [approvedById], references: [id])

  @@index([branchId, status])
  @@map("production_orders")
}

model PreReadyBatch {
  id             String   @id @default(cuid())
  branchId       String
  preReadyItemId String
  quantity       Decimal  @db.Decimal(14, 4)
  remainingQty   Decimal  @db.Decimal(14, 4)
  makingDate     DateTime @db.Date
  expiryDate     DateTime @db.Date
  createdAt      DateTime @default(now())

  // Relations
  branch       Branch       @relation(fields: [branchId], references: [id])
  preReadyItem PreReadyItem @relation(fields: [preReadyItemId], references: [id])

  @@index([branchId, expiryDate])
  @@index([preReadyItemId])
  @@map("pre_ready_batches")
}

// ─────────────────────────────────────────────────────────────────────────────
// PHASE 2 — INVENTORY & RECIPE ENGINE
// ─────────────────────────────────────────────────────────────────────────────

enum SupplierCategory {
  MEAT
  FISH
  VEGETABLES
  DAIRY
  SPICES
  CLEANING
  PACKAGING
  BEVERAGE
  GENERAL
}

/// Type of non-supplier liability tracked under Liabilities (Creditors).
/// UTILITY = electricity / gas / internet / water etc. LANDLORD = rent.
/// BANK / INDIVIDUAL = loans owed. OTHER = catch-all.
enum CreditorCategory {
  UTILITY
  LANDLORD
  BANK
  INDIVIDUAL
  OTHER
}

enum IngredientCategory {
  RAW
  CLEANING
  PACKAGED
  SPICE
  DAIRY
  BEVERAGE
  SUPPLY // non-recipe operational supplies — tissues, parcel bags, cleaner, plates
  OTHER
}

enum StockMovementType {
  PURCHASE // stock received from supplier
  SALE // auto-deducted on order creation
  VOID_RETURN // returned when order item is voided
  ADJUSTMENT // manual stock correction
  WASTE // waste/spoilage write-off
  OPERATIONAL_USE // manual usage log for non-recipe supplies (Inventory → Supplies)
  PRODUCTION_RECEIVED // bumped when a Pre-Ready batch finishes and its
                      // PreReadyItem.producesIngredientId is set — the
                      // produced yield is added to the linked Ingredient
                      // counter so menu recipes that reference it deduct
                      // from the same single source of truth.
}

enum StockUnit {
  KG
  G
  L
  ML
  PCS
  DOZEN
  BOX
  PACKET
  PACK
  BOTTLE
  BAG
  BUNDLE
  CAN
  JAR
  TIN
  CARTON
}

// Admin-defined stock units. Rows are paired with an ALTER TYPE
// "StockUnit" ADD VALUE at creation time so the enum accepts the value.
// Soft-delete hides the unit from dropdowns without touching the enum
// (Postgres can't drop enum values safely once in use).
model CustomUnit {
  id        String    @id @default(cuid())
  branchId  String
  code      String // stored uppercase, must also be present in the StockUnit enum
  label     String // display name
  createdAt DateTime  @default(now())
  deletedAt DateTime?

  branch Branch @relation(fields: [branchId], references: [id])

  @@unique([branchId, code])
  @@map("custom_units")
}

model Supplier {
  id               String           @id @default(cuid())
  branchId         String
  name             String
  contactName      String?
  phone            String?
  /// WhatsApp number in E.164 format (e.g. +8801712345678). Separate
  /// from `phone` because Meta requires the international form with
  /// no spaces or dashes. Null = supplier has no WhatsApp on file —
  /// "Send PO via WhatsApp" button is disabled for this supplier.
  whatsappNumber   String?
  email            String?
  address          String?
  notes            String?
  category         SupplierCategory @default(GENERAL)
  openingBalance   Decimal          @default(0) @db.Decimal(14, 2)
  totalDue         Decimal          @default(0) @db.Decimal(14, 2)
  isActive         Boolean          @default(true)
  visibleToCashier Boolean          @default(false) // Phase 7: show this supplier in POS purchasing
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  deletedAt        DateTime?

  // Relations
  branch              Branch               @relation(fields: [branchId], references: [id])
  ingredients         Ingredient[]
  ingredientSuppliers IngredientSupplier[]
  purchaseOrders      PurchaseOrder[]
  payments            SupplierPayment[]
  returns             PurchaseReturn[]
  adjustments         SupplierAdjustment[]

  @@index([branchId, isActive])
  @@map("suppliers")
}

/// Manual ledger correction posted by Owner/Manager to fix wrong opening
/// balances or other ledger discrepancies. Pure ledger-only — does NOT
/// touch any cash/bank Account, does NOT create an Expense mirror, does
/// NOT post to Mushak. The transaction adjusts `Supplier.totalDue` and
/// records an audit row here so the Suppliers ledger view can show the
/// adjustment as its own line. Negative amount = reduce debt, positive
/// amount = increase debt.
model SupplierAdjustment {
  id         String   @id @default(cuid())
  branchId   String
  supplierId String
  amount     Decimal  @db.Decimal(14, 2) // signed: − reduces debt, + increases debt
  reason     String
  recordedById String
  createdAt  DateTime @default(now())

  branch     Branch   @relation(fields: [branchId], references: [id])
  supplier   Supplier @relation(fields: [supplierId], references: [id])
  recordedBy Staff    @relation("SupplierAdjustmentBy", fields: [recordedById], references: [id])

  @@index([branchId, supplierId])
  @@map("supplier_adjustments")
}

model SupplierPayment {
  id              String   @id @default(cuid())
  branchId        String
  supplierId      String
  purchaseOrderId String?
  amount          Decimal  @db.Decimal(14, 2)
  paymentMethod   String   @default("CASH")
  reference       String?
  notes           String?
  paidById        String
  createdAt       DateTime @default(now())

  // Relations
  branch        Branch         @relation(fields: [branchId], references: [id])
  supplier      Supplier       @relation(fields: [supplierId], references: [id])
  purchaseOrder PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  paidBy        Staff          @relation("SupplierPaymentBy", fields: [paidById], references: [id])

  @@index([branchId, supplierId])
  @@map("supplier_payments")
}

// ─────────────────────────────────────────────────────────────────────────────
// LIABILITIES (CREDITORS) — non-supplier debts: utilities, rent, loans, etc.
// Mirrors the Supplier ledger shape (opening balance + bills + payments +
// adjustments) but lives in its own surface so purchasing reports stay
// untouched. Each payment posts to a cash/bank Account and auto-mirrors
// into Expense (category derived from creditor.defaultExpenseCategory).
// ─────────────────────────────────────────────────────────────────────────────
model Creditor {
  id                     String           @id @default(cuid())
  branchId               String
  name                   String
  category               CreditorCategory @default(OTHER)
  contactName            String?
  phone                  String?
  email                  String?
  address                String?
  notes                  String?
  /// Default Expense category posted when a payment is recorded
  /// against this creditor (RENT / UTILITIES / MISCELLANEOUS / etc).
  /// Reuses the existing ExpenseCategory enum.
  defaultExpenseCategory ExpenseCategory  @default(MISCELLANEOUS)
  openingBalance         Decimal          @default(0) @db.Decimal(14, 2)
  totalDue               Decimal          @default(0) @db.Decimal(14, 2)
  isActive               Boolean          @default(true)
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
  deletedAt              DateTime?

  branch      Branch               @relation(fields: [branchId], references: [id])
  bills       CreditorBill[]
  payments    CreditorPayment[]
  adjustments CreditorAdjustment[]

  @@index([branchId, isActive])
  @@map("creditors")
}

/// One bill incurred by a creditor (e.g. "April electricity"). Increments
/// Creditor.totalDue. NO cash account or Expense side effect — the bill is
/// owed but not yet paid. Payments create the Expense + Account hit.
model CreditorBill {
  id           String    @id @default(cuid())
  branchId     String
  creditorId   String
  description  String
  amount       Decimal   @db.Decimal(14, 2)
  billDate     DateTime  @default(now())
  dueDate      DateTime?
  notes        String?
  recordedById String
  createdAt    DateTime  @default(now())

  branch     Branch   @relation(fields: [branchId], references: [id])
  creditor   Creditor @relation(fields: [creditorId], references: [id])
  recordedBy Staff    @relation("CreditorBillBy", fields: [recordedById], references: [id])

  @@index([branchId, creditorId])
  @@map("creditor_bills")
}

/// Payment against a creditor's outstanding balance. Decrements
/// Creditor.totalDue, creates an Expense mirror with the creditor's
/// defaultExpenseCategory, and debits the linked cash/bank Account
/// via accountService.updateAccountForPayment.
model CreditorPayment {
  id            String   @id @default(cuid())
  branchId      String
  creditorId    String
  amount        Decimal  @db.Decimal(14, 2)
  paymentMethod String   @default("CASH")
  reference     String?
  notes         String?
  paidById      String
  createdAt     DateTime @default(now())

  branch   Branch   @relation(fields: [branchId], references: [id])
  creditor Creditor @relation(fields: [creditorId], references: [id])
  paidBy   Staff    @relation("CreditorPaymentBy", fields: [paidById], references: [id])

  @@index([branchId, creditorId])
  @@map("creditor_payments")
}

/// Manual ledger correction. Pure ledger-only — adjusts Creditor.totalDue
/// by the signed `amount`. Negative = reduce debt, positive = increase debt.
/// Does NOT touch cash, does NOT create an Expense, does NOT post to Mushak.
/// Mirrors SupplierAdjustment exactly.
model CreditorAdjustment {
  id           String   @id @default(cuid())
  branchId     String
  creditorId   String
  amount       Decimal  @db.Decimal(14, 2)
  reason       String
  recordedById String
  createdAt    DateTime @default(now())

  branch     Branch   @relation(fields: [branchId], references: [id])
  creditor   Creditor @relation(fields: [creditorId], references: [id])
  recordedBy Staff    @relation("CreditorAdjustmentBy", fields: [recordedById], references: [id])

  @@index([branchId, creditorId])
  @@map("creditor_adjustments")
}

model Ingredient {
  id                  String             @id @default(cuid())
  branchId            String
  supplierId          String?
  name                String
  itemCode            String? // unique inventory code e.g. RAW-001
  category            IngredientCategory @default(RAW)
  unit                StockUnit          @default(G) // stock/recipe unit (G, ML, KG, etc.)
  purchaseUnit        String? // supplier's selling unit (PACK, BOTTLE, BOX, BAG, etc.)
  purchaseUnitQty     Decimal            @default(1) @db.Decimal(14, 4) // 1 purchaseUnit = X stock units (e.g., 1 PACK = 200 G)
  currentStock        Decimal            @default(0) @db.Decimal(14, 4) // in stock unit
  minimumStock        Decimal            @default(0) @db.Decimal(14, 4)
  /// When true (default), the nightly auto-min-stock cron + manual
  /// "Recompute Min Stock" button will overwrite this row's
  /// minimumStock with the auto-calculated value. Flip false on
  /// items the admin wants to manage by hand (seasonal, slow-movers,
  /// safety-stock items) so the recompute leaves them alone.
  autoMinStock        Boolean            @default(true)
  costPerUnit         Decimal            @default(0) @db.Decimal(14, 4) // cost in paisa per STOCK unit
  costPerPurchaseUnit Decimal            @default(0) @db.Decimal(14, 4) // cost in paisa per PURCHASE unit
  isActive            Boolean            @default(true)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  deletedAt           DateTime?

  // ─── Variant Support ───
  parentId      String? // null = top-level (generic or standalone)
  hasVariants   Boolean @default(false) // true = parent with brand variants; stock lives on children
  brandName     String? // e.g. "Milk Butter", "Bread Pit"
  packSize      String? // e.g. "250G", "1L" — display label
  piecesPerPack Int? // e.g. 10 pcs per pack
  sku           String? // supplier barcode / SKU
  // Website display
  imageUrl           String? // square image for website ingredient display
  showOnWebsite      Boolean @default(true) // show ingredient name on website menu detail pages
  websiteDisplayName String? // optional alias rendered to customers (e.g. "Aromatic Garlic" hides internal "Garlic Powder"); falls back to `name` when null

  // Relations
  branch              Branch               @relation(fields: [branchId], references: [id])
  supplier            Supplier?            @relation(fields: [supplierId], references: [id])
  suppliers           IngredientSupplier[]
  recipeItems         RecipeItem[]
  movements           StockMovement[]
  purchaseOrderItems  PurchaseOrderItem[]
  wasteLogs           WasteLog[]
  preReadyRecipeItems PreReadyRecipeItem[]
  returnItems         PurchaseReturnItem[]
  parent              Ingredient?          @relation("IngredientVariants", fields: [parentId], references: [id])
  variants            Ingredient[]         @relation("IngredientVariants")
  /// Reverse-link to any PreReadyItem that produces stock for this
  /// Ingredient. One Ingredient should be paired with at most one
  /// PreReadyItem in v1; the array exists because Prisma requires it
  /// for the relation, not because multi-link is supported in code.
  producedBy          PreReadyItem[]       @relation("PreReadyProducesIngredient")

  @@index([branchId, isActive])
  @@index([itemCode])
  @@index([parentId])
  @@map("ingredients")
}

model IngredientSupplier {
  id           String @id @default(cuid())
  ingredientId String
  supplierId   String

  // Relations
  ingredient Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  supplier   Supplier   @relation(fields: [supplierId], references: [id])

  @@unique([ingredientId, supplierId])
  @@map("ingredient_suppliers")
}

model Recipe {
  id         String   @id @default(cuid())
  menuItemId String   @unique
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  menuItem MenuItem     @relation(fields: [menuItemId], references: [id])
  items    RecipeItem[]

  @@map("recipes")
}

model RecipeItem {
  id           String    @id @default(cuid())
  recipeId     String
  ingredientId String
  quantity     Decimal   @db.Decimal(14, 4) // how much of the ingredient per 1 serving
  unit         StockUnit @default(G) // unit of the quantity (may differ from ingredient's unit)

  // Relations
  recipe     Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredient Ingredient @relation(fields: [ingredientId], references: [id])

  @@unique([recipeId, ingredientId])
  @@map("recipe_items")
}

model StockMovement {
  id           String            @id @default(cuid())
  branchId     String
  ingredientId String
  type         StockMovementType
  quantity     Decimal           @db.Decimal(14, 4) // positive = IN, negative = OUT
  notes        String?
  orderId      String? // reference for SALE/VOID_RETURN movements
  staffId      String? // who performed ADJUSTMENT/WASTE
  /// When admin corrected the recorded quantity post-hoc (e.g. recipe
  /// said 10 KG instead of 10 G — the SALE row deducted the wrong
  /// amount). `quantity` is updated to the corrected value, the
  /// original value is preserved in `correctedFromQuantity` for
  /// audit, and `Ingredient.currentStock` is rebalanced by the delta
  /// in the same transaction. Reports keep summing `quantity` as
  /// before — they automatically see the corrected number.
  correctedAt           DateTime?
  correctedFromQuantity Decimal?  @db.Decimal(14, 4)
  correctionReason      String?
  createdAt    DateTime          @default(now())

  // Relations
  branch     Branch     @relation(fields: [branchId], references: [id])
  ingredient Ingredient @relation(fields: [ingredientId], references: [id])

  @@index([branchId, createdAt])
  @@index([ingredientId])
  @@map("stock_movements")
}

// ─────────────────────────────────────────────────────────────────────────────
// PHASE 3 — PURCHASING
// ─────────────────────────────────────────────────────────────────────────────

enum PurchaseOrderStatus {
  DRAFT
  SENT
  PARTIAL
  RECEIVED
  CANCELLED
}

model PurchaseOrder {
  id          String              @id @default(cuid())
  branchId    String
  supplierId  String
  status      PurchaseOrderStatus @default(DRAFT)
  notes       String?
  orderedAt   DateTime?
  expectedAt  DateTime?
  receivedAt  DateTime?
  // Receipt-level adjustments captured on receive: a flat discount the
  // supplier offered on the whole shipment, plus any extra fees (delivery,
  // labour, packaging) tacked on at delivery. All amounts in paisa.
  // The supplier ledger settles: items_total + extra_fees - discount.
  receiptDiscount        Decimal  @default(0) @db.Decimal(14, 2)
  receiptDiscountReason  String?
  /// JSON array of { label: string; amount: number } in paisa.
  receiptExtraFees       Json?
  /// Meta message id returned when this PO PDF was last sent over
  /// WhatsApp. Null = never sent. Useful for tracing back to Meta
  /// Business Manager and a future delivery-receipt webhook hookup.
  whatsappMessageId      String?
  whatsappSentAt         DateTime?
  createdById String
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  deletedAt   DateTime?

  // Relations
  branch           Branch              @relation(fields: [branchId], references: [id])
  supplier         Supplier            @relation(fields: [supplierId], references: [id])
  createdBy        Staff               @relation("POCreatedBy", fields: [createdById], references: [id])
  items            PurchaseOrderItem[]
  supplierPayments SupplierPayment[]
  returns          PurchaseReturn[]

  @@index([branchId, status])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id               String    @id @default(cuid())
  purchaseOrderId  String
  ingredientId     String
  unit             String? // ordering unit (KG, PACK, etc.) — if null, use ingredient's purchaseUnit or unit
  quantityOrdered  Decimal   @db.Decimal(14, 4)
  quantityReceived Decimal   @default(0) @db.Decimal(14, 4)
  unitCost         Decimal   @db.Decimal(14, 4) // cost in paisa per unit
  makingDate       DateTime? @db.Date
  expiryDate       DateTime? @db.Date
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Relations
  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  ingredient    Ingredient    @relation(fields: [ingredientId], references: [id])

  @@map("purchase_order_items")
}

// ─────────────────────────────────────────────────────────────────────────────
// PHASE 6 — STAFF & PAYROLL
// ─────────────────────────────────────────────────────────────────────────────

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
  PAID_LEAVE
  SICK_LEAVE
  FESTIVAL_LEAVE
}

/// Where a row's status came from. MANUAL = admin clicked it (always
/// wins over sync). TIPSOI = computed from a Tipsoi /api/v1/logs event.
enum AttendanceSource {
  MANUAL
  TIPSOI
}

enum PayrollStatus {
  DRAFT
  APPROVED
  PAID
}

model Attendance {
  id        String           @id @default(cuid())
  branchId  String
  staffId   String
  date      DateTime         @db.Date
  clockIn   DateTime?
  clockOut  DateTime?
  status    AttendanceStatus @default(PRESENT)
  notes     String?
  /// Where this row's status came from. Admin marks set MANUAL +
  /// manualOverride=true so the next Tipsoi sync skips the row.
  source    AttendanceSource @default(MANUAL)
  /// True when an admin has hand-set this row. The Tipsoi sync skips
  /// rows with this flag — clearing it (Restore from Tipsoi button)
  /// re-enables overwrites.
  manualOverride Boolean    @default(false)
  /// First clock event observed by the device on this shift date.
  /// Distinct from clockIn (which is admin-editable) — used to compute
  /// LATE / HALF_DAY against the staff's effective shiftStart even
  /// when admin later edits clockIn.
  syncedClockIn  DateTime?
  syncedClockOut DateTime?
  /// Tipsoi log uid that produced syncedClockIn. Guards against
  /// re-importing the same event (idempotency on sync re-runs).
  syncedFromUid  String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  // Relations
  branch Branch @relation(fields: [branchId], references: [id])
  staff  Staff  @relation(fields: [staffId], references: [id])

  @@unique([staffId, date])
  @@index([branchId, date])
  @@map("attendance")
}

model Payroll {
  id           String        @id @default(cuid())
  branchId     String
  staffId      String
  periodStart  DateTime      @db.Date
  periodEnd    DateTime      @db.Date
  baseSalary   Decimal       @db.Decimal(14, 2)
  deductions   Decimal       @default(0) @db.Decimal(14, 2)
  bonuses      Decimal       @default(0) @db.Decimal(14, 2)
  netPayable   Decimal       @db.Decimal(14, 2)
  daysPresent  Int           @default(0)
  daysAbsent   Int           @default(0)
  status       PayrollStatus @default(DRAFT)
  notes        String?
  approvedById String?
  approvedAt   DateTime?
  paidAt       DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  paidAmount Decimal @default(0) @db.Decimal(14, 2) // total paid so far

  // Relations
  branch     Branch           @relation(fields: [branchId], references: [id])
  staff      Staff            @relation(fields: [staffId], references: [id])
  approvedBy Staff?           @relation("PayrollApprover", fields: [approvedById], references: [id])
  payments   PayrollPayment[]

  @@index([branchId, periodStart])
  @@index([staffId])
  @@map("payrolls")
}

model PayrollPayment {
  id            String   @id @default(cuid())
  payrollId     String
  amount        Decimal  @db.Decimal(14, 2)
  paymentMethod String   @default("CASH")
  reference     String?
  notes         String?
  paidById      String
  createdAt     DateTime @default(now())

  // Relations
  payroll Payroll @relation(fields: [payrollId], references: [id], onDelete: Cascade)
  paidBy  Staff   @relation("PayrollPaidBy", fields: [paidById], references: [id])

  @@index([payrollId])
  @@map("payroll_payments")
}

// ─────────────────────────────────────────────────────────────────────────────
// PHASE 7 — WASTE MANAGEMENT
// ─────────────────────────────────────────────────────────────────────────────

// ─────────────────────────────────────────────────────────────────────────────
// LEAVE MANAGEMENT
// ─────────────────────────────────────────────────────────────────────────────

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum LeaveType {
  SICK
  CASUAL
  ANNUAL
  UNPAID
  OTHER
}

model LeaveApplication {
  id           String      @id @default(cuid())
  branchId     String
  staffId      String
  type         LeaveType   @default(CASUAL)
  status       LeaveStatus @default(PENDING)
  startDate    DateTime    @db.Date
  endDate      DateTime    @db.Date
  reason       String?
  reviewedById String?
  reviewedAt   DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  // Relations
  branch     Branch @relation(fields: [branchId], references: [id])
  staff      Staff  @relation("LeaveApplicant", fields: [staffId], references: [id])
  reviewedBy Staff? @relation("LeaveReviewer", fields: [reviewedById], references: [id])

  @@index([branchId, staffId])
  @@map("leave_applications")
}

enum WasteReason {
  SPOILAGE
  PREPARATION_ERROR
  OVERCOOKED
  CONTAMINATION
  EXPIRED
  OTHER
}

model WasteLog {
  id           String      @id @default(cuid())
  branchId     String
  ingredientId String
  quantity     Decimal     @db.Decimal(14, 4)
  reason       WasteReason @default(OTHER)
  notes        String?
  recordedById String
  createdAt    DateTime    @default(now())

  // Relations
  branch     Branch     @relation(fields: [branchId], references: [id])
  ingredient Ingredient @relation(fields: [ingredientId], references: [id])
  recordedBy Staff      @relation("WasteRecorder", fields: [recordedById], references: [id])

  @@index([branchId, createdAt])
  @@index([ingredientId])
  @@map("waste_logs")
}

// ─────────────────────────────────────────────────────────────────────────────
// WORK PERIODS
// ─────────────────────────────────────────────────────────────────────────────

model WorkPeriod {
  id           String    @id @default(cuid())
  branchId     String
  startedAt    DateTime  @default(now())
  endedAt      DateTime?
  startedById  String
  endedById    String?
  notes        String?
  openingCash  Decimal   @default(0) @db.Decimal(14, 2)
  openingMFS   Decimal   @default(0) @db.Decimal(14, 2)
  openingCard  Decimal   @default(0) @db.Decimal(14, 2)
  closingCash  Decimal?  @db.Decimal(14, 2)
  closingMFS   Decimal?  @db.Decimal(14, 2)
  closingCard  Decimal?  @db.Decimal(14, 2)
  balancesJson String? // JSON: { opening: {accId: amount}, closing: {accId: amount} }
  createdAt    DateTime  @default(now())

  // Relations
  branch    Branch @relation(fields: [branchId], references: [id])
  startedBy Staff  @relation("WorkPeriodStarter", fields: [startedById], references: [id])
  endedBy   Staff? @relation("WorkPeriodEnder", fields: [endedById], references: [id])

  @@index([branchId, startedAt])
  @@map("work_periods")
}

// ─────────────────────────────────────────────────────────────────────────────
// COOKING STATIONS / MULTI-PRINTER
// ─────────────────────────────────────────────────────────────────────────────

model CookingStation {
  id          String   @id @default(cuid())
  branchId    String
  name        String
  // Printer target for this section's KOT. Leaving all three NULL means
  // the section falls back to the desktop's default kitchen slot.
  printerName String? // Windows printer name (USB thermal driver) — os-printer mode
  printerIp   String? // Network thermal printer host
  printerPort Int? // Network thermal printer TCP port (default 9100 at runtime)
  // Per-section VAT opt-out. When false, items routed to this station are
  // excluded from the VAT base on new orders — useful for jurisdictions
  // that zero-rate certain categories (e.g. Bangladesh zero-rates some
  // beverages). The branch's master vatEnabled flag still wins: when VAT
  // is off branch-wide, no items are taxed regardless of section flags.
  vatEnabled  Boolean  @default(true)
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  branch    Branch     @relation(fields: [branchId], references: [id])
  menuItems MenuItem[]

  @@unique([branchId, name])
  @@map("cooking_stations")
}

// ─────────────────────────────────────────────────────────────────────────────
// UNIT CONVERSIONS
// ─────────────────────────────────────────────────────────────────────────────

model UnitConversion {
  id        String    @id @default(cuid())
  branchId  String
  fromUnit  StockUnit
  toUnit    StockUnit
  factor    Decimal   @db.Decimal(14, 6) // 1 fromUnit = factor toUnits
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Relations
  branch Branch @relation(fields: [branchId], references: [id])

  @@unique([branchId, fromUnit, toUnit])
  @@map("unit_conversions")
}

// ─────────────────────────────────────────────────────────────────────────────
// PURCHASE RETURNS
// ─────────────────────────────────────────────────────────────────────────────

enum ReturnStatus {
  REQUESTED
  APPROVED
  COMPLETED
  REJECTED
}

model PurchaseReturn {
  id              String       @id @default(cuid())
  branchId        String
  purchaseOrderId String?
  supplierId      String
  status          ReturnStatus @default(REQUESTED)
  notes           String?
  requestedById   String
  completedAt     DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  // Relations
  branch        Branch               @relation(fields: [branchId], references: [id])
  purchaseOrder PurchaseOrder?       @relation(fields: [purchaseOrderId], references: [id])
  supplier      Supplier             @relation(fields: [supplierId], references: [id])
  requestedBy   Staff                @relation("ReturnRequester", fields: [requestedById], references: [id])
  items         PurchaseReturnItem[]

  @@index([branchId])
  @@map("purchase_returns")
}

model PurchaseReturnItem {
  id               String  @id @default(cuid())
  purchaseReturnId String
  ingredientId     String
  quantity         Decimal @db.Decimal(14, 4)
  unitPrice        Decimal @db.Decimal(14, 4)

  // Relations
  purchaseReturn PurchaseReturn @relation(fields: [purchaseReturnId], references: [id], onDelete: Cascade)
  ingredient     Ingredient     @relation(fields: [ingredientId], references: [id])

  @@map("purchase_return_items")
}

// ─────────────────────────────────────────────────────────────────────────────
// BACKUP SYSTEM — OWNER-only database backups
// ─────────────────────────────────────────────────────────────────────────────

model BackupRecord {
  id          String   @id @default(cuid())
  filename    String
  fileUrl     String
  sizeBytes   Int
  type        String   @default("MANUAL") // MANUAL | AUTO | UPLOAD
  /// Gzipped backup payload stored in Postgres so downloads survive
  /// container restarts on ephemeral-disk hosts (DigitalOcean App
  /// Platform, etc.). Disk copy is still written best-effort for local
  /// dev convenience but the DB column is the source of truth.
  /// Nullable so rows created before the migration can still be listed
  /// (download will 404 for those — they were already gone from disk).
  data        Bytes?
  /// Object-storage key when a copy was successfully uploaded to
  /// DigitalOcean Spaces. Read order is DB → Spaces → disk so we
  /// survive losing either store. Null when Spaces is not configured
  /// or the upload failed (the DB copy is still authoritative).
  spacesKey   String?
  createdAt   DateTime @default(now())
  createdById String?

  @@index([createdAt])
  @@map("backup_records")
}

model BackupSchedule {
  id        String    @id @default("default")
  frequency String    @default("OFF") // OFF | DAILY | WEEKLY | MONTHLY
  timeHour  Int       @default(2) // 0-23, server local time
  retention Int       @default(10) // keep N most recent AUTO backups
  lastRunAt DateTime?
  updatedAt DateTime  @updatedAt

  @@map("backup_schedule")
}

// ─────────────────────────────────────────────────────────────────────────────
// DESKTOP DEVICES — Paired Windows cashier terminals
// ─────────────────────────────────────────────────────────────────────────────
// Each installation of apps/pos-desktop registers itself once via POST
// /devices/register using owner credentials. Server returns a long-lived
// opaque device token; only its bcrypt hash is stored here. Desktop
// authenticates subsequent cashier logins by presenting the token.

model Device {
  id          String    @id @default(cuid())
  branchId    String
  name        String // "Front Counter", "Register 2"
  tokenHash   String // bcrypt hash of the device token
  lastSeenAt  DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  revokedAt   DateTime?
  createdById String? // Staff.id of the owner/manager who paired the device

  branch Branch @relation(fields: [branchId], references: [id])

  @@index([branchId, isActive])
  @@map("devices")
}

// ─────────────────────────────────────────────────────────────────────────────
// IDEMPOTENCY — safe retries for mutation endpoints
// ─────────────────────────────────────────────────────────────────────────────
// Desktop terminals attach an Idempotency-Key header to every mutating
// request. If the network hiccups mid-drain and the same request replays,
// the server returns the cached response instead of executing twice.

model IdempotencyRecord {
  key          String   @id
  method       String
  path         String
  responseCode Int
  responseBody String // JSON-serialized body
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@map("idempotency_records")
}

// ─────────────────────────────────────────────────────────────────────────────
// MUSHAK — Bangladesh NBR VAT compliance (6.3 invoices + 6.8 credit/debit notes)
// ─────────────────────────────────────────────────────────────────────────────
// Every paid order on a branch with `nbrEnabled=true` gets a MushakInvoice
// (form 6.3) with a per-branch, per-fiscal-year sequential serial. Refunds
// emit a MushakNote (form 6.8) linked to the original invoice. Both carry a
// frozen `snapshot` JSON so re-prints stay legally stable even after menu
// prices or VAT rates change later. The sequence table is upserted atomically
// inside the same transaction that writes the invoice/note, so concurrent
// terminals can't reuse or skip a seq.

model MushakSequence {
  id          String   @id @default(cuid())
  branchId    String
  fiscalYear  String // "2526" for BD FY Jul-2025 → Jun-2026
  docKind     String // "INVOICE" (6.3) or "NOTE" (6.8) — separate counters
  lastSeq     Int      @default(0)
  updatedAt   DateTime @updatedAt

  branch Branch @relation(fields: [branchId], references: [id])

  @@unique([branchId, fiscalYear, docKind])
  @@map("mushak_sequences")
}

model MushakInvoice {
  id               String   @id @default(cuid())
  branchId         String
  orderId          String   @unique
  serial           String   @unique // e.g. "2526/DHK/000147"
  fiscalYear       String
  branchCode       String
  seq              Int
  formVersion      String   @default("6.3")
  issuedAt         DateTime @default(now())
  // Buyer block — denormalised from Customer at issue time so later edits
  // to the customer record don't mutate the invoice.
  buyerName        String?
  buyerPhone       String?
  buyerAddress     String?
  buyerBin         String?
  // Frozen totals (decimals mirror Order). All values are post-discount,
  // pre-VAT subtotal + VAT breakdown so the PDF can be rebuilt verbatim.
  subtotalExclVat  Decimal  @db.Decimal(14, 2)
  sdAmount         Decimal  @default(0) @db.Decimal(14, 2)
  vatAmount        Decimal  @db.Decimal(14, 2)
  totalInclVat     Decimal  @db.Decimal(14, 2)
  // Full frozen JSON: seller block, buyer, every line with qty/rate/VAT/SD,
  // totals, timestamps, cashier name. Used by the reprint template — never
  // re-computed from live order data.
  snapshot         Json
  createdAt        DateTime @default(now())

  branch Branch      @relation(fields: [branchId], references: [id])
  order  Order       @relation(fields: [orderId], references: [id])
  notes  MushakNote[]

  @@unique([branchId, fiscalYear, seq])
  @@index([branchId, issuedAt])
  @@map("mushak_invoices")
}

model MushakNote {
  id               String          @id @default(cuid())
  branchId         String
  invoiceId        String
  orderId          String
  serial           String          @unique // e.g. "2526/DHK/NOTE/000023"
  fiscalYear       String
  branchCode       String
  seq              Int
  formVersion      String          @default("6.8")
  noteType         MushakNoteType
  reasonCode       RefundReason
  reasonText       String?
  issuedAt         DateTime        @default(now())
  issuedById       String
  // Refund totals — negative for CREDIT notes (refund), positive for DEBIT.
  subtotalExclVat  Decimal         @db.Decimal(14, 2)
  sdAmount         Decimal         @default(0) @db.Decimal(14, 2)
  vatAmount        Decimal         @db.Decimal(14, 2)
  totalInclVat     Decimal         @db.Decimal(14, 2)
  // JSON array of OrderItem ids actually refunded (empty when full-order).
  refundedItemIds  Json
  // Frozen JSON mirroring MushakInvoice.snapshot — used for slip reprint.
  snapshot         Json
  createdAt        DateTime        @default(now())

  branch   Branch        @relation(fields: [branchId], references: [id])
  invoice  MushakInvoice @relation(fields: [invoiceId], references: [id])
  order    Order         @relation(fields: [orderId], references: [id])
  issuedBy Staff         @relation("MushakNoteIssuer", fields: [issuedById], references: [id])

  @@unique([branchId, fiscalYear, seq])
  @@index([branchId, issuedAt])
  @@index([invoiceId])
  @@map("mushak_notes")
}

// ─────────────────────────────────────────────────────────────────────────────
// LICENSE — installed-side cache of this install's license state
// ─────────────────────────────────────────────────────────────────────────────
// The CodeCanyon edition gates access to the API behind a verified license
// from neawaslic.top. This table is the LOCAL CACHE of the verdict — the
// authoritative state lives on the license server. Keeping a singleton row
// + an append-only checklog here means:
//   • the gate can answer in O(1) without hitting the network on every req
//   • offline grace works even if neawaslic is unreachable
//   • database-row tampering is detected via verdictHmac (HMAC keyed on
//     machineId + bundled public key, computed at write time)
//   • cracker visibility — LicenseCheckLog's append-only breadcrumbs make
//     "I ripped out the assertions" obvious in support
//
// Singleton: enforced at the service layer (we always upsert against the
// well-known id 'self'). Buyer who deletes the row triggers re-activation;
// tampering with status/expiresAt invalidates the HMAC and forces a fresh
// verify against neawaslic.

enum LicenseStatus {
  PENDING
  ACTIVE
  EXPIRED
  REVOKED
}

enum LicenseCheckAction {
  ACTIVATE
  VERIFY
  DEACTIVATE
  ASSERT
  BLOCKED
}

model LicenseRecord {
  id               String        @id @default("self")
  licenseId        String        @unique
  // Last 8 chars of the purchase code, kept as a humans-readable hint
  // for support ("which code is this install on?"). Full code is never
  // persisted — the hmacSecret derived from it is the only stored secret.
  purchaseCodeTail String
  activatedDomain  String
  fingerprint      String
  hmacSecretEnc    String
  status           LicenseStatus @default(PENDING)

  // Cached signed proof from the server. Verifies offline using the
  // bundled ed25519 public key. Re-fetched on every successful verify.
  signedProof String @db.Text

  // Wall-clock timestamps. graceUntil is COMPUTED from lastVerifiedAt +
  // (proof.graceUntil - proof.issuedAt) so a clock-rewind can't extend it.
  lastVerifiedAt DateTime
  expiresAt      DateTime?
  graceUntil     DateTime?

  // HMAC of the row's authoritative fields keyed on machineId + bundled
  // public key. Mismatch on read → treat row as missing and force
  // re-activation. Defeats trivial DB edits like
  //   UPDATE license_records SET status='ACTIVE', expiresAt=NULL;
  verdictHmac String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("license_records")
}

model LicenseCheckLog {
  id        String             @id @default(cuid())
  action    LicenseCheckAction
  result    String // "active", "grace day 3", "locked: REVOKED", etc
  ip        String?
  userAgent String?
  path      String?
  at        DateTime           @default(now())

  @@index([at])
  @@index([action, at])
  @@map("license_check_logs")
}

// ─────────────────────────────────────────────────────────────────────────────
// SYSTEM CONFIG — install wizard sentinel + brand defaults
// ─────────────────────────────────────────────────────────────────────────────
// Singleton row (id 'self'). The install wizard sets `installedAt` once it
// finishes and from that point onward the /install/* routes 404. Buyer can
// later edit the brand fields from Settings; the wizard does NOT touch them
// after install completes.
//
// Why a separate model from BranchSetting: settings are PER-BRANCH (a chain
// can theme each location), but install state + the global brand identity
// are PER-INSTALL. Putting them on Branch would couple "did the wizard run?"
// to "which branch is the operator looking at?", which falls apart on
// multi-branch installs and on day-zero (no branch exists yet).

model SystemConfig {
  id           String    @id @default("self")
  // null until the wizard's last step finishes. The InstallGuard checks
  // this single column to decide whether to serve the wizard routes or
  // 404 them. Buyer who wipes this row gets the wizard back — by design.
  installedAt  DateTime?
  brandName    String    @default("Your Restaurant")
  siteName     String    @default("Your Restaurant")
  logoUrl      String?
  supportEmail String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("system_config")
}

// ─────────────────────────────────────────────────────────────────────────────
// UPDATER — in-app zip upload + apply flow
// ─────────────────────────────────────────────────────────────────────────────
// Tracks every update attempt so the Settings → Updates page can show
// history (previous version, when applied, whether rolled back) and
// support can diagnose buyers who crashed mid-update.
//
// Flow a row goes through:
//   upload   → Buyer drops a zip. We save to updates/staging/<id>/zip,
//              unzip, verify manifest.sig against the bundled public
//              key. Row created with status=STAGED.
//   apply    → Buyer clicks Apply. We create a DB backup (reuse
//              BackupService), run `prisma migrate deploy` from the
//              staged tree's schema, atomically swap current/ ↔ new/,
//              write applyMarker.json, then exit. PM2 restarts us
//              pointing at the new code. Row status=APPLIED after the
//              new process confirms health on the other side.
//   rollback → If the post-apply health check fails (or buyer hits
//              the button), swap back, restore DB from backup, mark
//              row ROLLED_BACK + write the failure reason.

enum UpdateStatus {
  STAGED       // zip uploaded + signature OK, not yet applied
  APPLYING     // apply started; file swap + migrate in progress
  APPLIED      // new version booted + health-checked ok
  ROLLED_BACK  // apply failed health or buyer chose to revert
  FAILED       // upload or pre-apply verification hard-failed
}

model UpdateRecord {
  id              String       @id @default(cuid())
  // Semver from the staged release's manifest.json.
  toVersion       String
  fromVersion     String
  status          UpdateStatus @default(STAGED)
  // Where on disk the staged zip + extracted tree live. Cleaned up
  // only AFTER a successful apply + a second successful update — we
  // keep one previous tree around as the rollback target.
  stagingPath     String
  // ID of the pre-apply backup (from BackupRecord) so a manual
  // rollback can find its snapshot even after the row's prev-tree
  // dir is cleaned up.
  backupRecordId  String?
  // SHA-256 of the uploaded zip, for idempotency + tamper checks
  // across the staging lifetime.
  zipSha256       String
  // Human-readable note captured from the buyer's Apply Reason text
  // box + any auto-failure diagnostic.
  notes           String?      @db.Text
  uploadedById    String?      // Staff.id of the OWNER who uploaded
  uploadedAt      DateTime     @default(now())
  appliedAt       DateTime?
  rolledBackAt    DateTime?

  @@index([uploadedAt])
  @@index([status, uploadedAt])
  @@map("update_records")
}

// ─── SMS ──────────────────────────────────────────────────────────────────────
// Log of every SMS attempt — outbound campaigns, payment receipts, OTPs that
// the admin cares about seeing. request_id comes from api.sms.net.bd and is
// used later to poll the status endpoint. `status` starts as QUEUED, flips to
// SENT when the gateway accepts, then DELIVERED / FAILED / EXPIRED based on
// the periodic poll. Retry support: set status back to QUEUED + clear
// requestId + bump attempts.
enum SmsStatus {
  QUEUED
  SENT
  DELIVERED
  FAILED
  EXPIRED
}

enum SmsKind {
  CAMPAIGN
  PAYMENT
  RESERVATION
  OTP
  OTHER
}

model SmsLog {
  id          String    @id @default(cuid())
  branchId    String
  toPhone     String
  body        String    @db.Text
  kind        SmsKind   @default(OTHER)
  status      SmsStatus @default(QUEUED)
  requestId   String?   // api.sms.net.bd request_id — poll key
  errorText   String?   // last error from gateway, if any
  attempts    Int       @default(1)
  // Optional joins — which customer / order / campaign prompted this send.
  customerId  String?
  orderId     String?
  campaignId  String?   // free-form — groups rows sent by one bulk action
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lastChecked DateTime? // last time we polled the status endpoint

  @@index([branchId, createdAt])
  @@index([branchId, status])
  @@index([campaignId])
  @@map("sms_logs")
}

// Reusable SMS bodies for the admin campaign composer. Uses {{name}} and
// {{phone}} placeholders — {{name}} falls back to "Dear Customer" when the
// customer record has no name.
model SmsTemplate {
  id        String   @id @default(cuid())
  branchId  String
  name      String   // display name in the admin picker
  body      String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([branchId, name])
  @@index([branchId])
  @@map("sms_templates")
}

// ─────────────────────────────────────────────────────────────────────────────
// ACTIVITY LOG — admin-config audit trail
// ─────────────────────────────────────────────────────────────────────────────
// Records who/when/what for every admin-config mutation (menu, recipes,
// ingredients, suppliers, expenses, accounts, settings, etc.). Order /
// payment audit lives in their own purpose-built fields (Order.voidedAt,
// OrderItem, OrderPayment, StockMovement, AccountTransaction) — not here.
// Retention: 90 days, auto-purged nightly by ActivityLogScheduler.

enum ActivityCategory {
  MENU
  RECIPE
  INGREDIENT
  SUPPLIER
  PURCHASING
  EXPENSE
  ACCOUNT
  PAYROLL
  CUSTOMER
  STAFF
  BRANCH
  DISCOUNT
  RESERVATION
  WASTE
  PRE_READY
  SETTINGS
  PERMISSIONS
  COOKING_STATION
  TABLE
}

enum ActivityAction {
  CREATE
  UPDATE
  DELETE
}

model ActivityLog {
  id         String           @id @default(cuid())
  branchId   String
  /// Who performed the action. Nullable so system-generated entries
  /// (cron auto-cleanup, scheduled jobs) still log without a user
  /// and so a deleted Staff row doesn't cascade-remove their audit
  /// trail (onDelete: SetNull).
  actorId    String?
  /// Frozen at log time so a future staff rename / role change
  /// doesn't rewrite history.
  actorName  String?
  actorRole  String?

  category   ActivityCategory
  action     ActivityAction

  /// Domain entity touched (e.g. "menuItem", "ingredient",
  /// "supplier"). Drives both per-category filters and the
  /// per-entity drill-in view.
  entityType String
  entityId   String
  /// Frozen display name so the log reads "Orange Juice" even if
  /// the row was renamed or deleted later.
  entityName String

  /// Field-level diff. Shape:
  ///   UPDATE: { fieldName: { before: any, after: any } }
  ///   CREATE: { __after: { ...full row } }
  ///   DELETE: { __before: { ...full row } }
  /// Sensitive fields (password hash, token, secret, PIN hash) are
  /// stripped in the service before serialising — they never reach
  /// the DB.
  diff       Json?
  /// Optional one-line headline ("price ৳10.00 → ৳12.00") computed
  /// by the service. Falls back to "<action> <entityType>
  /// <entityName>" in the UI when null.
  summary    String?

  createdAt  DateTime         @default(now())

  branch     Branch           @relation(fields: [branchId], references: [id])
  actor      Staff?           @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([branchId, createdAt])
  @@index([branchId, category, createdAt])
  @@index([entityType, entityId, createdAt])
  @@map("activity_logs")
}
